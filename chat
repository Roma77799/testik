local function spawnBubbleFrame(stack, text, remainingTime)
    local msgFrame = Instance.new("Frame")
    msgFrame.BackgroundColor3 = Color3.fromRGB(25, 27, 29)
    msgFrame.BackgroundTransparency = 0.3
    msgFrame.AutomaticSize = Enum.AutomaticSize.XY
    msgFrame.Parent = stack
    Instance.new("UICorner", msgFrame).CornerRadius = UDim.new(0, 8)

    -- ограничение на фрейм, а не на лейбл — фикс бага с пропадающим текстом
    local constraint = Instance.new("UISizeConstraint")
    constraint.MaxSize = Vector2.new(220, 9999)
    constraint.Parent = msgFrame

    local bPadding = Instance.new("UIPadding")
    bPadding.PaddingLeft   = UDim.new(0, 10)
    bPadding.PaddingRight  = UDim.new(0, 10)
    bPadding.PaddingTop    = UDim.new(0, 6)
    bPadding.PaddingBottom = UDim.new(0, 6)
    bPadding.Parent = msgFrame

    local bLabel = Instance.new("TextLabel")
    bLabel.Size = UDim2.new(1, 0, 0, 0)  -- ширина от родителя, высота авто
    bLabel.AutomaticSize = Enum.AutomaticSize.Y
    bLabel.BackgroundTransparency = 1
    bLabel.Text = text
    bLabel.TextColor3 = Color3.new(1, 1, 1)
    bLabel.Font = Enum.Font.GothamMedium
    bLabel.TextSize = 14
    bLabel.RichText = true
    bLabel.TextWrapped = true
    bLabel.Parent = msgFrame

    task.spawn(function()
        task.wait(remainingTime)
        if not msgFrame or not msgFrame.Parent then return end
        local tInfo = TweenInfo.new(0.5)
        TweenService:Create(msgFrame, tInfo, { BackgroundTransparency = 1 }):Play()
        TweenService:Create(bLabel,   tInfo, { TextTransparency = 1 }):Play()
        task.wait(0.5)
        if msgFrame and msgFrame.Parent then msgFrame:Destroy() end
    end)
end

local function createBubble(text)
    local bGui = getOrCreateBubbleGui()
    if not bGui then return end
    local stack = bGui:FindFirstChild("Stack")
    if not stack then return end

    local removeAt = tick() + 25
    table.insert(pendingBubbles, { text = text, removeAt = removeAt })

    spawnBubbleFrame(stack, text, 25)

    task.delay(25.5, function()
        local now = tick()
        for i = #pendingBubbles, 1, -1 do
            if pendingBubbles[i].removeAt <= now then
                table.remove(pendingBubbles, i)
            end
        end
    end)
end
local function onCharacterAdded(character)
    local hrp = character:WaitForChild("HumanoidRootPart", 10)
    if not hrp then return end
    task.wait(0.15)

    local now = tick()
    for i = #pendingBubbles, 1, -1 do
        if pendingBubbles[i].removeAt <= now then
            table.remove(pendingBubbles, i)
        end
    end

    if #pendingBubbles == 0 then return end

    local bGui = rebuildBubbleGui()
    if not bGui then return end
    local stack = bGui:FindFirstChild("Stack")
    if not stack then return end

    for _, bubble in ipairs(pendingBubbles) do
        local remaining = bubble.removeAt - now
        if remaining > 0 then
            spawnBubbleFrame(stack, bubble.text, remaining)
        end
    end
end

