    container.AnchorPoint = Vector2.new(0, 1)
    container.Size = UDim2.new(1, 0, 1, 0)
    container.Position = UDim2.new(0, 0, 1, 0)
    container.BackgroundTransparency = 1
    container.ClipsDescendants = false
    container.Parent = bGui

    local layout = Instance.new("UIListLayout")
    layout.VerticalAlignment   = Enum.VerticalAlignment.Bottom
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    layout.SortOrder     = Enum.SortOrder.LayoutOrder
    layout.FillDirection = Enum.FillDirection.Vertical
    layout.Padding       = UDim.new(0, 5)
    layout.Parent = container

    return bGui
end

local function wsConnect()
    local ok, result = pcall(function()
        return WebSocket.connect("ws://92.246.139.177:1000")
    end)
    if not ok then
        warn("ChatService: connect failed:", result)
        task.delay(5, wsConnect)
        return
    end

    ws = result
    wsConnected = true

    ws:Send(HttpService:JSONEncode({
        type  = "register",
        jobId = getgenv().haha,
        name  = player.Name,
    }))

    ws.OnMessage:Connect(function(raw)
        local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
        if not ok2 or type(data) ~= "table" then return end

        if data.type == "spam_warn" then
            local remaining = tonumber(data.remaining) or 60
            addMessage("System", "Too many request. Wait " .. remaining .. " sec.", Color3.fromRGB(255, 80, 80))
            return
        end

        if data.type ~= "chat" then return end
        if type(data.name) ~= "string" or type(data.text) ~= "string" then return end

        addMessage(data.name, data.text)

        local targetPlayer = Players:FindFirstChild(data.name)
        if not targetPlayer or not targetPlayer.Character then return end
        local hrp = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        local bGui = getOrBuildOtherBubbleGui(hrp, data.name)
        local stack = bGui and bGui:FindFirstChild("Stack")
        if stack then
            spawnBubbleFrame(stack, data.text, 8)
        end
    end)

    ws.OnClose:Connect(function()
        wsConnected = false
        ws = nil
        warn("ChatService: closed reconnect wait 5s...")
        task.delay(5, wsConnect)
    end)
end

task.spawn(wsConnect)

RunService.RenderStepped:Connect(function()
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local bGui = hrp:FindFirstChild("CustomBubbleGui")
    if not bGui then return end

    local camera = workspace.CurrentCamera

    -- берём экранную позицию самого hrp
    local hrpScreen, onScreen = camera:WorldToScreenPoint(hrp.Position)
    if not onScreen then return end

    -- хотим чтобы bubble был правее на фиксированные 160 пикселей
    local targetScreenX = hrpScreen.X + 160
    local targetScreenY = hrpScreen.Y

    -- переводим обратно в 3D на той же глубине
    local targetWorld = camera:ScreenPointToRay(targetScreenX, targetScreenY).Origin
        + camera:ScreenPointToRay(targetScreenX, targetScreenY).Direction * (hrpScreen.Z)

    -- считаем разницу в world space относительно hrp
    local offset = hrp.CFrame:PointToObjectSpace(targetWorld)

    bGui.StudsOffset = Vector3.new(offset.X, 1.5, offset.Z)
end)
