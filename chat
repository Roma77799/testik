end

local function addMessage(sender, text, color)
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 0)
    label.AutomaticSize = Enum.AutomaticSize.Y
    label.BackgroundTransparency = 1
    label.Font = Enum.Font.Gotham
    label.TextSize = 14
    label.TextColor3 = color or Color3.new(1, 1, 1)
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.RichText = true
    label.TextWrapped = true
    label.Text = "<b>" .. sender .. ":</b> " .. text
    label.Parent = messageList
    task.wait()
    messageList.CanvasPosition = Vector2.new(0, messageList.AbsoluteCanvasSize.Y)
    updateScrollThumb()
end

local function onSend()
    local text = chatInput.Text
    if text == "" or text:match("^%s*$") then return end
    addMessage(player.Name, text)
    createBubble(text)
    chatInput.Text = ""
    if wsConnected and ws then
        pcall(function()
            ws:Send(HttpService:JSONEncode({
                type = "chat",
                text = text,
            }))
        end)
    end
end

