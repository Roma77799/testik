local dragging = false
local dragStart
local dragWindowStart

chatWindow.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch)
    and not isResizing and not isDraggingScrollThumb then
        dragging = true
        dragActiveInput = input
        dragStart = input.Position
        dragWindowStart = chatWindow.AbsolutePosition
        resetActivityTimer()
    end
end)

UserInputService.InputChanged:Connect(function(input)
    local isDragMove = dragging and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or (input.UserInputType == Enum.UserInputType.Touch and input == dragActiveInput)
    )
    if not isDragMove then return end
    local delta    = input.Position - dragStart
    local viewport = workspace.CurrentCamera.ViewportSize
    local winSize  = chatWindow.AbsoluteSize
    chatWindow.AnchorPoint = Vector2.new(0, 0)
    chatWindow.Position = UDim2.fromOffset(
        math.clamp(dragWindowStart.X + delta.X, 0, viewport.X - winSize.X),
        math.clamp(dragWindowStart.Y + delta.Y, 0, viewport.Y - winSize.Y)
    )
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if dragging then
            lastPosition = chatWindow.Position
            lastAnchor   = chatWindow.AnchorPoint
        end
        dragging   = false
        dragActiveInput = nil
        isResizing = false
        isDraggingScrollThumb = false
    end
end)

