local function requestServerList()
    if wsConnected and ws then
        pcall(function()
            ws:Send(HttpService:JSONEncode({ type = "get_servers" }))
        end)
    end
end

local function openServerList()
    serverListVisible = true
    serverListWindow.AnchorPoint = serverListLastAnchor
    serverListWindow.Position    = serverListLastPos
    serverListWindow.Size        = serverListLastSize
    serverListWindow.Visible     = true
    serverListBtn.Image = "rbxassetid://85034401017513"
    requestServerList()
end

local function closeServerList()
    serverListVisible = false
    serverListWindow.Visible = false
    serverListBtn.Image = "rbxassetid://117293331356936"
end

slCloseBtn.MouseButton1Click:Connect(closeServerList)
serverListBtn.MouseButton1Click:Connect(function()
    if serverListVisible then closeServerList() else openServerList() end
end)

serverListWindow.InputBegan:Connect(function(input)
    if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch)
    and not serverListResizing then
        serverListDragging = true
        serverListDragActiveInput = input
        serverListDragStart = input.Position
        serverListDragWindowStart = serverListWindow.AbsolutePosition
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if serverListDragging and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or (input.UserInputType == Enum.UserInputType.Touch and input == serverListDragActiveInput)
    ) then
        local d       = input.Position - serverListDragStart
        local viewport = workspace.CurrentCamera.ViewportSize
        local winSize  = serverListWindow.AbsoluteSize
        serverListWindow.AnchorPoint = Vector2.new(0, 0)
        serverListWindow.Position = UDim2.fromOffset(
            math.clamp(serverListDragWindowStart.X + d.X, 0, viewport.X - winSize.X),
            math.clamp(serverListDragWindowStart.Y + d.Y, 0, viewport.Y - winSize.Y)
        )
    end
    if serverListResizing and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or (input.UserInputType == Enum.UserInputType.Touch and input == serverListResizeActiveInput)
    ) then
        local mousePos = input.Position
        local viewport = workspace.CurrentCamera.ViewportSize
        local winPos   = serverListWindow.AbsolutePosition
        serverListWindow.Size = UDim2.new(0,
            math.clamp(mousePos.X - winPos.X, 240, math.min(700, viewport.X - winPos.X)),
            0,
            math.clamp(mousePos.Y - winPos.Y, 140, math.min(600, viewport.Y - winPos.Y))
        )
        serverListLastSize = serverListWindow.Size
    end
end)

slResizeHandle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        serverListResizing = true
        serverListResizeActiveInput = input
        TweenService:Create(slResizeImage, TweenInfo.new(0.1), { ImageTransparency = 0.35 }):Play()
    end
end)

slResizeHandle.MouseEnter:Connect(function()
    TweenService:Create(slResizeImage, TweenInfo.new(0.3,
        Enum.EasingStyle.Exponential, Enum.EasingDirection.Out),
        { ImageTransparency = 0.8 }):Play()
end)

slResizeHandle.MouseLeave:Connect(function()
    if not serverListResizing then
        TweenService:Create(slResizeImage, TweenInfo.new(0.3,
            Enum.EasingStyle.Exponential, Enum.EasingDirection.Out),
            { ImageTransparency = 1 }):Play()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if serverListDragging then
            serverListLastPos    = serverListWindow.Position
            serverListLastAnchor = serverListWindow.AnchorPoint
        end
        if serverListResizing then
            TweenService:Create(slResizeImage, TweenInfo.new(0.17), { ImageTransparency = 1 }):Play()
        end
        serverListDragging = false
        serverListDragActiveInput = nil
        serverListResizing = false
        serverListResizeActiveInput = nil
    end
end)

task.spawn(function()
    while true do
        task.wait(3)
        if serverListVisible then
            requestServerList()
        end
    end
end)

local function wsConnect()
    local ok, result = pcall(function()
        return WebSocket.connect("ws://92.246.139.177:1000")
    end)
    if not ok then
        warn("ChatService: connect failed:", result)
        task.delay(5, wsConnect)
        return
    end

    ws = result
    wsConnected = true

    ws:Send(HttpService:JSONEncode({
        type  = "register",
        jobId = getgenv().haha,
        name  = player.Name,
    }))

    ws.OnMessage:Connect(function(raw)
        local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
        if not ok2 or type(data) ~= "table" then return end

        if data.type == "color_assign" then
            myColorHex = tostring(data.color or "#FFFFFF")
            return
        end

        if data.type == "self_join" then
            addMessage("System", "You connected to SNPWARE CHAT!", Color3.fromRGB(131, 255, 100))
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "SNPWARE CHAT";
                Text  = "You connected to the server!";
                Duration = 5;
            })
            return
        end

        if data.type == "join" then
            local name = tostring(data.name or "?")
            addMessage("System", name .. " connected to server!", Color3.fromRGB(136, 255, 100))
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "SNPWARE CHAT";
                Text  = name .. " connected to server!";
                Duration = 5;
            })
            return
        end

        if data.type == "leave" then
            local name = tostring(data.name or "?")
            addMessage("System", name .. " left the server.", Color3.fromRGB(180, 180, 180))
            game:GetService("StarterGui"):SetCore("SendNotification", {
                Title = "SNPWARE CHAT";
                Text  = name .. " left the server.";
                Duration = 5;
            })
            return
        end

        if data.type == "spam_warn" then
            local remaining = tonumber(data.remaining) or 60
            addMessage("System", "Too many request. Wait " .. remaining .. " sec.", Color3.fromRGB(255, 80, 80))
            return
        end

        if data.type == "server_list" then
            if type(data.servers) == "table" then
                updateServerListUI(data.servers)
            end
            return
        end

        if data.type ~= "chat" then return end
        if type(data.name) ~= "string" or type(data.text) ~= "string" then return end

        addMessage(data.name, data.text, nil, tostring(data.color or "#FFFFFF"))
    end)

    ws.OnClose:Connect(function()
        wsConnected = false
        ws = nil
        warn("ChatService: closed reconnect wait 5s...")
        task.delay(5, wsConnect)
    end)
end

task.spawn(wsConnect)

