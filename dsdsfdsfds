local CoreGui = game:GetService("CoreGui")
local props = {
    "ClassName", "Name", "Size", "Position", "BackgroundColor3", 
    "BackgroundTransparency", "Text", "TextColor3", "Image", 
    "Visible", "ZIndex", "AnchorPoint", "TextSize", "Font",
    "Thickness", "Color", "ApplyStrokeMode", "CornerRadius"
}
local function getTargetFolder()
    local _, res = pcall(function()
        local base = CoreGui:WaitForChild("10da44577f5dca6201c46c31f68b1072382d4b83cb3b666547904cb2bca6bf2a", 5)
        local gFolder = base and base:WaitForChild("_g0e25751", 5)
        return gFolder and gFolder:WaitForChild("HoneyFeatureActionButtons", 5)
    end)
    return res
end
local TargetFolder = getTargetFolder()
if not TargetFolder then 
    warn("[-] Путь не найден") 
    return 
end
local function dumpInstance(obj)
    local data = {}
    for _, prop in ipairs(props) do
        pcall(function()
            local v = obj[prop]
            if v ~= nil then
                if typeof(v) == "Color3" then
                    data[prop] = string.format("Color3.fromRGB(%d, %d, %d)", math.floor(v.R*255), math.floor(v.G*255), math.floor(v.B*255))
                elseif typeof(v) == "UDim2" then
                    data[prop] = "UDim2.new(" .. tostring(v) .. ")"
                elseif typeof(v) == "Vector2" then
                    data[prop] = "Vector2.new(" .. tostring(v) .. ")"
                elseif typeof(v) == "string" then
                    data[prop] = '"' .. v .. '"'
                else
                    data[prop] = tostring(v)
                end
            end
        end)
    end
    
    data.Children = {}
    for _, child in ipairs(obj:GetChildren()) do
        table.insert(data.Children, dumpInstance(child))
    end
    return data
end
local function tableToString(t, indent)
    indent = indent or ""
    local str = "{\n"
    for k, v in pairs(t) do
        if k == "Children" then
            if #v > 0 then
                str = str .. indent .. '  ["Children"] = {\n'
                for _, child in ipairs(v) do
                    str = str .. indent .. "    " .. tableToString(child, indent .. "    ") .. ",\n"
                end
                str = str .. indent .. "  }\n"
            end
        else
            str = str .. indent .. '  ["' .. k .. '"] = ' .. tostring(v) .. ",\n"
        end
    end
    return str .. indent .. "}"
end
TargetFolder.ChildAdded:Connect(function(child)
    task.wait(0.2)
    print("[+] Изменения в структуре: " .. child.Name)
    
    local success, dumpedData = pcall(dumpInstance, child)
    if success and dumpedData then
        local finalString = tableToString(dumpedData)
        
        -- Вот он, твой setclipboard, теперь на видном месте :)
        if setclipboard then
            setclipboard(finalString)
            print("[*] Данные скопированы в буфер обмена!")
        else
            print(finalString)
            warn("[-] setclipboard не поддерживается эксплойтом.")
        end
    else
        warn("[-] Ошибка дампа")
    end
end)
print("[!] Скрипт запущен и слушает: " .. TargetFolder:GetFullName())
