connectHandlers()

local function parseTradePartner(value)
    if not value then return nil end
    if type(value) == "userdata" then
        local ok, name = pcall(function() return value.Name end)
        if ok and name then return tostring(name) end
    end
    if type(value) == "string" and value ~= "" then
        return value
    end
    return nil
end

Trade.StartTrade.OnClientEvent:Connect(function(arg1, arg2)
    local name = parseTradePartner(arg2) or ""
    print("StartTrade, игрок:", name)
    botLog("remote", "StartTrade partner=" .. tostring(name))
    connectHandlers()

    if name ~= "" and namesMatch(targetName, name) then
        print("✅ жертва в StartTrade")
        botLog("trade", "entered StartTrade victim=" .. tostring(name))
        botLogSnapshot("StartTrade")
    elseif name == "" then
        print("⚠️ StartTrade без имени партнёра — не отклоняем")
        botLog("trade", "StartTrade empty partner name")
    else
        print("❌ не жертва в StartTrade:", name, "ожидали:", tostring(targetName))
        botLog("action", "DeclineTrade wrong partner=" .. tostring(name))
        telegramTrade("StartTrade: чужой партнёр", "от: " .. tostring(name) .. ", ожидали: " .. tostring(targetName))
        skipTgOnce("DeclineTrade")
        botFireTrade("DeclineTrade", Trade.DeclineTrade)
    end
end)

Trade.AcceptTrade.OnClientEvent:Connect(function(arg1, arg2)
    print("AcceptTrade, ended:", tostring(arg1))
    botLog("remote", "AcceptTrade ended=" .. tostring(arg1) .. " lastOffer=" .. tostring(lastOfferTime))
    if not arg1 then
        if not lastOfferTime or tonumber(lastOfferTime) == 0 then
            print("⚠️ AcceptTrade без LastOffer — пропускаем")
            botLog("action", "AcceptTrade skipped no LastOffer")
