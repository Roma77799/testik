local Trade = ReplicatedStorage:WaitForChild("Trade", 100)

local function connectHandlers()
    Trade.SendRequest.OnClientInvoke = function(arg1)
        if not arg1 then
            Trade.DeclineRequest:FireServer()
            return false
        end

        local senderName = type(arg1) == "userdata" and arg1.Name or tostring(arg1)
        print("SendRequest от:", senderName)

        if targetName == senderName then
            print("✅ жертва кинула запрос")
            Trade.AcceptRequest:FireServer()
            return true
        else
            print("❌ не жертва:", senderName)
            Trade.DeclineRequest:FireServer()
            return false
        end
    end
end

-- первичное подключение
connectHandlers()

Trade.StartTrade.OnClientEvent:Connect(function(arg1, arg2)
