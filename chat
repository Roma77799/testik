    local function slUpdateScrollThumb()
        local canvasHeight = slScrollFrame.AbsoluteCanvasSize.Y
        local viewHeight   = slScrollFrame.AbsoluteWindowSize.Y
        local trackHeight  = slScrollTrack.AbsoluteSize.Y
        if viewHeight <= 0 or trackHeight <= 0 or canvasHeight <= viewHeight then
            slScrollTrack.Visible = false
            slScrollThumb.Position = UDim2.fromOffset(0, 0)
            slScrollThumb.Size = UDim2.new(1, 0, 1, 0)
            return
        end
        slScrollTrack.Visible = true
        local thumbHeight = math.clamp(math.floor((viewHeight / canvasHeight) * trackHeight), 24, trackHeight)
        local maxCanvasY  = math.max(0, canvasHeight - viewHeight)
        local scrollRatio = maxCanvasY > 0 and (slScrollFrame.CanvasPosition.Y / maxCanvasY) or 0
        local maxThumbY   = math.max(0, trackHeight - thumbHeight)
        local thumbY      = math.floor(maxThumbY * math.clamp(scrollRatio, 0, 1))
        slScrollThumb.Size     = UDim2.new(1, 0, 0, thumbHeight)
        slScrollThumb.Position = UDim2.fromOffset(0, thumbY)
    end

    local function slSetScrollFromThumb(offsetY)
        local trackHeight  = slScrollTrack.AbsoluteSize.Y
        local thumbHeight  = slScrollThumb.AbsoluteSize.Y
        local canvasHeight = slScrollFrame.AbsoluteCanvasSize.Y
        local viewHeight   = slScrollFrame.AbsoluteWindowSize.Y
        local maxThumbY    = math.max(0, trackHeight - thumbHeight)
        local maxCanvasY   = math.max(0, canvasHeight - viewHeight)
        if maxThumbY <= 0 or maxCanvasY <= 0 then
            slScrollFrame.CanvasPosition = Vector2.new(0, 0)
            return
        end
        slScrollFrame.CanvasPosition = Vector2.new(0, math.floor(maxCanvasY * math.clamp(offsetY / maxThumbY, 0, 1)))
    end

