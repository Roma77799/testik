local function isLogicClass(className)
	return LOGIC_CLASSES[className] == true
end

local function trimPropertiesForMode(obj, properties)
	local mode = Exporter.Config.exportMode
	if mode ~= "logic" and mode ~= "minimal" then
		return properties
	end

	local allow = MINIMAL_PROPS[obj.ClassName]
	if not allow then
		return properties
	end

	local trimmed = {}
	for key, value in pairs(properties) do
		if allow[key] then
			trimmed[key] = value
		end
	end
	if properties.Name ~= nil then trimmed.Name = properties.Name end
	if properties.ClassName ~= nil then trimmed.ClassName = properties.ClassName end
	return trimmed
end

-- ---------------------------------------------------------------------------
-- Tree path registry (fix sibling name collisions)
-- ---------------------------------------------------------------------------

function Exporter.isOrphanInstance(obj)
	if obj == gameRoot then
		return false
	end
	local roots = Exporter._exportRoots
	if not roots then
		local ok, under = pcall(function()
			return obj:IsDescendantOf(gameRoot)
		end)
		return not (ok and under)
	end
	for _, root in ipairs(roots) do
		if obj == root then
			return false
		end
		local ok, under = pcall(function()
			return obj:IsDescendantOf(root)
		end)
		if ok and under then
			return false
		end
	end
	return true
end

local function buildPathFromObject(obj)
	local parts = {}
	local current = obj
	for _ = 1, 64 do
		if not current then
			break
		end
		table.insert(parts, 1, sanitizeSegment(current.Name))
		if current == gameRoot then
			break
		end
		current = current.Parent
	end
	if #parts == 0 then
		return nil
	end
	return table.concat(parts, "/")
end

local function getRelativePath(obj, fullName, index, className)
	if not Exporter.isOrphanInstance(obj) then
		local chainPath = buildPathFromObject(obj)
		if chainPath and #chainPath > 0 then
			return chainPath
		end
		if fullName and fullName:find(".", 1, true) then
			return fullNameToRelativePath(fullName)
		end
		return sanitizeSegment(obj.Name)
	end
	return pathJoin("_nil", ("%05d_%s_%s"):format(index, className, sanitizeSegment(obj.Name)))
end

local function resolveUniquePath(baseRelative, registry)
	local count = registry[baseRelative] or 0
	registry[baseRelative] = count + 1

	if count == 0 then
		return baseRelative
	end
	return baseRelative .. ("__%d"):format(count + 1)
end

local function readProperty(obj, propName, isHidden)
	local value, err

	if isHidden and type(gethiddenproperty) == "function" then
		local ok, result = pcall(gethiddenproperty, obj, propName)
		if ok then
			return result, nil
		end
		err = tostring(result)
	elseif isHidden then
		return nil, "gethiddenproperty unavailable"
	else
		local ok, result = pcall(function()
			return obj[propName]
		end)
		if ok then
			return result, nil
		end
		err = tostring(result)
	end

	return nil, err
end

local function collectProperties(obj)
	local properties = {}
	local hiddenProperties = {}
	local errors = {}
	local collected = {}
	local mode = (Exporter and Exporter.Config and Exporter.Config.propertiesMode) or "fast"

	if type(getproperties) == "function" then
		local ok, props = pcall(getproperties, obj)
		if ok and type(props) == "table" then
			for name, value in pairs(props) do
				collected[name] = true
				local success, ser = pcall(serializeValue, value)
				if success then
					if type(ser) == "table" and ser.__type == "Color3" and ser._invalid then
						local fixed = rereadColor3Property(obj, name)
						ser = fixed or ser
					end
					properties[name] = ser
				else
					errors[name] = ser
				end
			end
		end
	end

	if mode == "full" and loadApiDump() then
		for _, propDef in ipairs(getClassPropertyDefs(obj.ClassName)) do
			local name = propDef.name
			if not collected[name] and not collected[name:lower()] then
				local isHidden = propDef.tags.Hidden or propDef.tags.NotScriptable
				local value, readErr = readProperty(obj, name, isHidden)

				if readErr and not isHidden then
					value, readErr = readProperty(obj, name, true)
					isHidden = value ~= nil
				end

				if value ~= nil or readErr == nil then
					collected[name] = true
					local success, ser = pcall(serializeValue, value)
					local target = isHidden and hiddenProperties or properties
					if success then
						if type(ser) == "table" and ser.__type == "Color3" and ser._invalid then
							ser = rereadColor3Property(obj, name) or ser
						end
						target[name] = ser
					else
						target[name] = { __error = tostring(ser) }
					end
				elseif readErr then
					errors[name] = readErr
				end
			end
		end
	end

	properties = dedupeProperties(properties)
	hiddenProperties = dedupeProperties(hiddenProperties)
	properties = trimPropertiesForMode(obj, properties)

	local cfg = Exporter.Config
	local attributes = nil
	local tags = nil

	local wantTags = cfg.includeTags
		or (cfg.exportMode == "logic" and (obj:IsA("Model") or obj:IsA("Folder") or obj:IsA("ProximityPrompt")))

	if cfg.includeAttributes then
		attributes = {}
		pcall(function()
			for attrName, attrValue in pairs(obj:GetAttributes()) do
				attributes[attrName] = {
					value = serializeValue(attrValue),
					valueType = typeof(attrValue),
				}
			end
		end)
		if not next(attributes) then
			attributes = nil
		end
	end

	if wantTags then
		tags = {}
		pcall(function()
			local CollectionService = game:GetService("CollectionService")
			for _, tag in ipairs(CollectionService:GetTags(obj)) do
				tags[#tags + 1] = tag
			end
		end)
		if #tags == 0 then
			tags = nil
		end
	end

	return properties, hiddenProperties, attributes, tags, errors
end

-- ---------------------------------------------------------------------------
-- Script source sidecar
-- ---------------------------------------------------------------------------

local function exportScriptSource(obj, exportRoot, relativePath)
	if not obj:IsA("LuaSourceContainer") then
		return nil
	end

	local sidecar = {}

	if type(decompile) == "function" then
		local viable = false
		if obj:IsA("ModuleScript") then
			viable = true
		elseif obj:IsA("LocalScript") then
			viable = obj.RunContext == Enum.RunContext.Client or obj.RunContext == Enum.RunContext.Legacy
		elseif obj:IsA("Script") then
			viable = obj.RunContext == Enum.RunContext.Client
		end

		if viable then
			local ok, source = pcall(decompile, obj)
			if ok and type(source) == "string" then
				local luaPath = pathJoin(exportRoot, "scripts", relativePath .. ".lua")
				local wrote, writeErr = writeFileSafe(luaPath, source)
				if wrote then
					sidecar.decompiledPath = luaPath
				else
					sidecar.decompileError = tostring(writeErr)
				end
			else
				sidecar.decompileError = tostring(source)
			end
		else
			sidecar.decompileSkipped = "not client-viable"
		end
	end

	if type(getscriptbytecode) == "function" and Exporter.Config.saveBytecode then
		local ok, bytecode = pcall(getscriptbytecode, obj)
		if ok and type(bytecode) == "string" then
			local bcPath = pathJoin(exportRoot, "bytecode", relativePath .. ".txt")
			local wrote, writeErr = writeFileSafe(bcPath, bytecode)
			if wrote then
				sidecar.bytecodePath = bcPath
			else
				sidecar.bytecodeError = tostring(writeErr)
			end
		end
	end

	return sidecar
end

