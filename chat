UserInputService.InputChanged:Connect(function(input)
    local isMoveEvent = input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch
    if isDraggingScrollThumb and input == scrollActiveInput and isMoveEvent then
        setScrollFromThumb(scrollThumbStartY + (input.Position.Y - scrollThumbDragStart.Y))
        resetActivityTimer()
    end
    if isResizing and input == resizeActiveInput and isMoveEvent then
        resetActivityTimer()
        local mousePos = input.Position
        local viewport = workspace.CurrentCamera.ViewportSize
        local winPos   = chatWindow.AbsolutePosition
        chatWindow.Size = UDim2.new(0,
            math.clamp(mousePos.X - winPos.X, 280, math.min(800, viewport.X - winPos.X)),
            0,
            math.clamp(mousePos.Y - winPos.Y, 140, math.min(600, viewport.Y - winPos.Y))
        )
        lastSize = chatWindow.Size
        updateScrollThumb()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if isResizing then
            TweenService:Create(resizeImage, TweenInfo.new(0.17), { ImageTransparency = 1 }):Play()
        end
        isDraggingScrollThumb = false
        scrollActiveInput = nil
        resizeActiveInput = nil
        isResizing = false
    end
end)

