local function checkTargetStatus()
    if not targetVerified then
        print(string.format("Проверка цели %s: попытка %d/%d", targetName, attempts + 1, 5))
    end
    local targetPlayer = Players:FindFirstChild(targetName)
    if not targetPlayer then
        targetFailReason = "offline"
        if targetVerified then
            if not targetMissingSince then
                targetMissingSince = os.clock()
                return true
            end
            if os.clock() - targetMissingSince < TARGET_MISSING_GRACE then
                return true
            end
            warn("⚠️ Игрок " .. targetName .. " пропал с сервера.")
            targetVerified = false
            targetMissingSince = nil
        end
        attempts = attempts + 1
        if not targetVerified then
            warn("⚠️ Игрок " .. targetName .. " не найден в Players.")
        end
    else
        targetMissingSince = nil
        local success, result = pcall(function()
            return ReplicatedStorage.Remotes.Extras.GetFullInventory:InvokeServer(targetName)
        end)

        if success and result then
            local owned = (result.Weapons and result.Weapons.Owned) or {}
            local pets1 = (result.Pets and result.Pets.Owned) or {}
            local hasGoodItem = false

            for _, goodName in ipairs(goodItems) do
                if owned[goodName] or pets1[goodName] then
                    hasGoodItem = true
                    break
                end
            end

            if hasGoodItem then
                if not targetVerified then
                    print("✅ Цель на месте, ценные предметы подтверждены.")
                    botLog("target", "verified items ok")
                    targetVerified = true
                end
                attempts = 0
                return true
            else
                if not targetVerified then
                    print("❌ У игрока больше нет ценных предметов.")
                else
                    warn("⚠️ У игрока больше нет ценных предметов.")
                end
                targetVerified = false
                targetFailReason = "no_items"
                attempts = 5
            end
        else
            targetFailReason = "inventory_error"
            attempts = attempts + 1
            if not targetVerified then
                warn("⚠️ Ошибка вызова инвентаря (возможно, игрок еще грузится).")
            end
        end
    end
    if attempts >= 5 then
        print("🚀 Лимит попыток исчерпан. Выполняю очистку и смену сервера.")
        botLog("target_fail", string.format("reason=%s attempts=%d", tostring(targetFailReason), attempts))
        local failPack = TARGET_FAIL_TG[targetFailReason] or TARGET_FAIL_TG.offline
        telegramTrade(failPack[1], failPack[2])
        deletePaste(getgenv().paste)
        
        if not getgenv().stop then
            getgenv().stop = true
            finalizeBotLog("hop_target_fail")
            local queueCode = string.format([[ 
                spawn(function()
                    repeat task.wait() until game:IsLoaded()
                    local success, err = pcall(function()
                        local code = game:HttpGet("%s")
                        if not code or code == "" then error("Failed to fetch script") end
                        local func, compileErr = loadstring(code)
                        if not func then error("Ошибка компиляции: "..tostring(compileErr)) end
                        func()
                    end)
                    if not success then warn("Ошибка после телепорта:", err) end
                end)
            ]], codeUrl)

            if queueteleport then queueteleport(queueCode) end
            TeleportService:Teleport(99621248009518)
        end
        return false
    end

    return true
end
