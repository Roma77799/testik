end)

--// Основная логика получения данных
local function getOldestPaste()
    if isProcessing then return true end 

    -- 1. Получаем список с антикэшем (?t=...)
    local success, response = pcall(function()
        return request({
            Url = "https://pastefy.app/api/v2/user/pastes?t=" .. os.time(),
            Method = "GET",
            Headers = headers
        })
    end)

    if not success or not response or response.StatusCode ~= 200 then
        return false, "Ошибка API (Status: "..(response and response.StatusCode or "nil")..")"
    end

    local ok, data = pcall(function() return HttpService:JSONDecode(response.Body) end)
    if not ok or type(data) ~= "table" or #data == 0 then
        return false, "Паст нет"
    end

    -- Сортировка по дате
    table.sort(data, function(a, b)
        return parseDateTime(a.created_at) < parseDateTime(b.created_at)
    end)

    -- Поиск первой валидной пасты
    local oldest = nil
    for _, p in ipairs(data) do
        if p.id ~= lastDeletedId and not blacklistedPastes[p.id] then
            oldest = p
            break
        end
    end

    if not oldest then return false, "Паст нет (все в ЧС или удалены)" end

    -- 2. Валидация пасты (проверка на 404 перед телепортом)
    local checkReq = request({
        Url = "https://pastefy.app/api/v2/paste/" .. oldest.id,
        Method = "GET",
        Headers = headers
    })

    if checkReq.StatusCode == 404 then
        warn("🚫 Обнаружена призрачная паста: " .. oldest.id .. ". Пропускаю.")
        blacklistedPastes[oldest.id] = true
        return false, "Пропуск призрака"
    end

    -- 3. Разбор контента
    local content = oldest.content or ""
    local lines = {}
    for line in content:gmatch("[^\r\n]+") do table.insert(lines, line) end

    local jobId = lines[1]
    local gameid = lines[2]
    local playerName = lines[3]

    if not jobId or not gameid or jobId == "" or gameid == "" then
        warn("⚠️ Паста " .. oldest.id .. " повреждена. Удаляю.")
        deletePaste(oldest.id)
        blacklistedPastes[oldest.id] = true
        return false, "Битая паста удалена"
    end

    -- Подготовка к телепорту
    getgenv().name = playerName or ""
    getgenv().paste = oldest.id
    isProcessing = true 

    local queueCode = string.format([[ 
        getgenv().name = "%s"
        getgenv().paste = "%s"
        spawn(function()
            repeat task.wait() until game:IsLoaded()
            local success, err = pcall(function()
                local code = game:HttpGet("%s")
                if not code or code == "" then error("Failed to fetch script") end
                local func, compileErr = loadstring(code)
                if not func then error("Ошибка компиляции: "..tostring(compileErr)) end
                func()
            end)
            if not success then warn("Ошибка после телепорта:", err) end
        end)
    ]], getgenv().name, getgenv().paste, codeUrl)

    if queueteleport then queueteleport(queueCode) end

    print("🚀 Попытка телепорта: " .. jobId)
    TeleportService:TeleportToPlaceInstance(tonumber(gameid) or gameid, jobId)
    
    return true 
end

print("Скрипт запущен (с защитой от кэша и 404)...")

while true do
    local ok, result, msg = pcall(getOldestPaste)
    
    if not ok then
        local errorText = tostring(result)
        warn("⚠️ Ошибка выполнения:", errorText)
        task.wait(errorText:find("Timedout") and 15 or 6)

    elseif result == false then
        if msg ~= "Паст нет" then 
            warn("Статус:", msg) 
        end
        
        -- Если Pastefy выдает ошибки 5xx, ждем дольше
        if tostring(msg):find("503") or tostring(msg):find("504") then
            task.wait(15)
        else
            task.wait(6)
        end
    else
        task.wait(6)
    end
end
