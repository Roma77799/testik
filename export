-- ---------------------------------------------------------------------------
-- Filesystem helpers
-- ---------------------------------------------------------------------------

local function requireFs(name)
	local fn = getfenv()[name]
	if type(fn) ~= "function" then
		error(("Exporter requires %s (sUNC Filesystem). See https://docs.sunc.su/Filesystem/"):format(name), 0)
	end
	return fn
end

local writefile = requireFs("writefile")
local makefolder = requireFs("makefolder")
local readfile = getfenv().readfile
local appendfile = getfenv().appendfile
local isfolder = getfenv().isfolder
local isfile = getfenv().isfile

local function pathJoin(...)
	local parts = {...}
	local path = table.concat(parts, "/")
	return path:gsub("/+", "/"):gsub("^/", ""):gsub("/$", "")
end

local WINDOWS_RESERVED = {
	CON = true, PRN = true, AUX = true, NUL = true,
	COM1 = true, COM2 = true, COM3 = true, COM4 = true,
	LPT1 = true, LPT2 = true, LPT3 = true,
}

local function hashPath(str)
	local h = 0
	for i = 1, #str do
		h = (h * 31 + string.byte(str, i)) % 2147483647
	end
	return string.format("%07x", h)
end

local function sanitizeSegment(name)
	local s = tostring(name)
	s = s:gsub("[%c]", "_")
	s = s:gsub("[*\\?:<>|\"/]", "_")
	s = s:gsub("^[%s%.]+", ""):gsub("[%s%.]+$", "")
	if s == "" then
		s = "_empty"
	end
	local head = s:upper():match("^([^%.]+)")
	if head and WINDOWS_RESERVED[head] then
		s = "_" .. s
	end
	return s:gsub("%.", "_"):sub(1, 80)
end

local function fullNameToRelativePath(fullName)
	local segments = string.split(fullName, ".")
	for i = 1, #segments do
		segments[i] = sanitizeSegment(segments[i])
	end
	return table.concat(segments, "/")
end

local folderCache = {}

local function ensureFolder(path)
	if not path or path == "" then
		return true
	end
	if folderCache[path] then
		return true
	end
	if isfolder and isfolder(path) then
		folderCache[path] = true
		return true
	end
	local built = ""
	for segment in string.gmatch(path, "[^/]+") do
		built = (built == "") and segment or (built .. "/" .. segment)
		if not folderCache[built] and not (isfolder and isfolder(built)) then
			local ok, err = pcall(makefolder, built)
			if not ok then
				return false, err or ("could not create directory: " .. built)
			end
		end
		folderCache[built] = true
	end
	return true
end

local function writeFileSafe(path, contents)
	local dir = path:match("^(.*)/[^/]+$") or ""
	local okDir, dirErr = ensureFolder(dir)
	if not okDir then
		return false, dirErr
	end
	local ok, err = pcall(writefile, path, contents)
	if not ok then
		return false, err or ("could not write file: " .. path)
	end
	return true
end

local function writeJson(path, data)
	local ok, encoded = pcall(HttpService.JSONEncode, HttpService, data)
	if not ok then
		encoded = HttpService:JSONEncode({
			_error = "JSONEncode failed",
			_message = tostring(encoded),
		})
	end
	return writeFileSafe(path, encoded)
end

local function capRelativePath(relativePath, exportRoot, index, className)
	local maxLen = Exporter.Config.maxPathLength or 200
	local treePath = pathJoin(exportRoot, "tree", relativePath .. ".json")
	if #treePath <= maxLen then
		return relativePath, nil
	end
	local hash = hashPath(relativePath)
	local short = pathJoin("_long", ("%05d_%s_%s"):format(index, sanitizeSegment(className), hash))
	return short, relativePath
end

-- ---------------------------------------------------------------------------
-- Value serialization (lossless / typed)
-- ---------------------------------------------------------------------------

local function base64Encode(raw)
	if type(raw) ~= "string" then
		return nil
	end
	if crypt and crypt.base64 and crypt.base64.encode then
		local ok, out = pcall(crypt.base64.encode, raw)
		if ok then return out end
	end
	return nil
end

local function serializeValue(value, depth)
	depth = depth or 0
	if depth > 12 then
		return { __type = "MaxDepth" }
	end

	local t = typeof(value)

	if value == nil then
		return nil
	end

	if t == "boolean" or t == "number" then
		if t == "number" and (value ~= value or value == math.huge or value == -math.huge) then
			return { __type = "number", value = tostring(value) }
		end
		return value
	end

	if t == "string" then
		return value
	end

	if t == "EnumItem" then
		return {
			__type = "EnumItem",
			enumType = tostring(value.EnumType),
			name = value.Name,
			value = value.Value,
		}
	end

	if t == "Instance" then
		local fullName = ""
		pcall(function()
			fullName = value:GetFullName()
		end)
		return {
			__type = "Instance",
			className = value.ClassName,
			name = value.Name,
			fullName = fullName,
		}
	end

	if t == "Vector2" then
		return { __type = "Vector2", x = value.X, y = value.Y }
	end

	if t == "Vector3" then
		return { __type = "Vector3", x = value.X, y = value.Y, z = value.Z }
	end

	if t == "CFrame" then
		local components = { value:GetComponents() }
		return { __type = "CFrame", components = components }
	end

	if t == "Color3" then
		local r, g, b = value.R, value.G, value.B
		if r > 1 or g > 1 or b > 1 then
			if r <= 255 and g <= 255 and b <= 255 then
				r, g, b = r / 255, g / 255, b / 255
			else
				return { __type = "Color3", _invalid = true, raw = { r = r, g = g, b = b } }
			end
		end
		return { __type = "Color3", r = r, g = g, b = b }
	end

	if t == "BrickColor" then
		return { __type = "BrickColor", name = value.Name, number = value.Number }
	end

	if t == "UDim" then
		return { __type = "UDim", scale = value.Scale, offset = value.Offset }
	end

	if t == "UDim2" then
		return {
			__type = "UDim2",
			xScale = value.X.Scale, xOffset = value.X.Offset,
			yScale = value.Y.Scale, yOffset = value.Y.Offset,
		}
	end

	if t == "Rect" then
		return {
			__type = "Rect",
			min = serializeValue(value.Min, depth + 1),
			max = serializeValue(value.Max, depth + 1),
		}
	end

	if t == "Ray" then
		return {
			__type = "Ray",
			origin = serializeValue(value.Origin, depth + 1),
			direction = serializeValue(value.Direction, depth + 1),
		}
	end

	if t == "NumberRange" then
		return { __type = "NumberRange", min = value.Min, max = value.Max }
	end

	if t == "PhysicalProperties" then
		return {
			__type = "PhysicalProperties",
			density = value.Density,
			friction = value.Friction,
			elasticity = value.Elasticity,
			frictionWeight = value.FrictionWeight,
			elasticityWeight = value.ElasticityWeight,
		}
	end

	if t == "Faces" then
		return {
			__type = "Faces",
			back = value.Back, bottom = value.Bottom, front = value.Front,
			left = value.Left, right = value.Right, top = value.Top,
		}
	end

	if t == "Axes" then
		return { __type = "Axes", x = value.X, y = value.Y, z = value.Z }
	end

	if t == "Region3" then
		local cf, size = value.CFrame, value.Size
		return {
			__type = "Region3",
			cframe = serializeValue(cf, depth + 1),
			size = serializeValue(size, depth + 1),
		}
	end

	if t == "RectOffset" then
		return {
			__type = "RectOffset",
			top = value.Top, bottom = value.Bottom,
			left = value.Left, right = value.Right,
		}
	end

	if t == "Font" then
		return {
			__type = "Font",
			family = value.Family,
			weight = serializeValue(value.Weight, depth + 1),
			style = serializeValue(value.Style, depth + 1),
		}
	end

	if t == "ColorSequence" then
		local keypoints = {}
		for _, kp in ipairs(value.Keypoints) do
			keypoints[#keypoints + 1] = {
				time = kp.Time,
				color = serializeValue(kp.Value, depth + 1),
			}
		end
		return { __type = "ColorSequence", keypoints = keypoints }
	end

	if t == "NumberSequence" then
		local keypoints = {}
		for _, kp in ipairs(value.Keypoints) do
			keypoints[#keypoints + 1] = {
				time = kp.Time,
				value = kp.Value,
				envelope = kp.Envelope,
			}
		end
		return { __type = "NumberSequence", keypoints = keypoints }
	end

	if t == "NumberSequenceKeypoint" then
		return {
			__type = "NumberSequenceKeypoint",
			time = value.Time, value = value.Value, envelope = value.Envelope,
		}
	end

	if t == "ColorSequenceKeypoint" then
		return {
			__type = "ColorSequenceKeypoint",
			time = value.Time,
			value = serializeValue(value.Value, depth + 1),
		}
	end

	if t == "Content" or t == "BinaryString" then
		local b64 = base64Encode(tostring(value))
		return {
			__type = t,
			base64 = b64,
			length = #tostring(value),
			unavailable = b64 == nil,
		}
	end

	if t == "ProtectedString" then
		local raw = tostring(value)
		return {
			__type = "ProtectedString",
			length = #raw,
			base64 = base64Encode(raw),
		}
	end

	if t == "SecurityCapabilities" then
		return { __type = "SecurityCapabilities", value = tonumber(value) or tostring(value) }
	end

	if t == "SharedTable" then
		return { __type = "SharedTable", value = tostring(value) }
	end

	if t == "buffer" then
		return { __type = "buffer", value = tostring(value) }
	end

	-- table (rare for property values)
	if t == "table" then
		local out = { __type = "table" }
		for k, v in pairs(value) do
			out[tostring(k)] = serializeValue(v, depth + 1)
		end
		return out
	end

	return { __type = t, value = tostring(value) }
end

-- ---------------------------------------------------------------------------
-- Roblox API reflection (property names per class)
-- ---------------------------------------------------------------------------

local ApiCache = { loaded = false, classes = {} }

local function parseApiDump(raw)
	local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
	if not ok or type(data) ~= "table" then
		return false
	end

	local classes = {}
	for _, class in ipairs(data.Classes or {}) do
		local props = {}
		for _, member in ipairs(class.Members or {}) do
			if member.MemberType == "Property" then
				local tags = {}
				if member.Tags then
					for _, tag in ipairs(member.Tags) do
						tags[tag] = true
					end
				end
				props[#props + 1] = {
					name = member.Name,
					valueType = member.ValueType and member.ValueType.Name or "unknown",
					category = member.Category or "Other",
					tags = tags,
					security = member.Security,
				}
			end
		end
		classes[class.Name] = {
			name = class.Name,
			superclass = class.Superclass,
			properties = props,
		}
	end

	ApiCache.classes = classes
	ApiCache.loaded = true
	return true
end

local function loadApiDump()
	if ApiCache.loaded then
		return true
	end

	local cachePath = "export/_cache/api_dump.json"
	if isfile and isfile(cachePath) then
		local ok, raw = pcall(readfile, cachePath)
		if ok and raw and #raw > 0 and parseApiDump(raw) then
			return true
		end
	end

	local ver = "version-"
	if type(version) == "function" then
		local ok, v = pcall(version)
		if ok and type(v) == "string" then
			ver = v
		end
	end

	local url = ("http://setup.roblox.com/%s-API-Dump.json"):format(ver)
	local raw
	if type(game.HttpGet) == "function" then
		raw = game:HttpGet(url)
	elseif type(game.HttpGetAsync) == "function" then
		raw = game:HttpGetAsync(url)
	else
		warn("[Exporter] Cannot fetch API dump — using getproperties-only mode")
		return false
	end

	if not parseApiDump(raw) then
		return false
	end

	ensureFolder("export/_cache")
	writefile(cachePath, raw)
	return true
end

local function getClassPropertyDefs(className)
	local defs = {}
	local seen = {}
	local current = className

	while current and ApiCache.classes[current] do
		local classData = ApiCache.classes[current]
		for i = #classData.properties, 1, -1 do
			local prop = classData.properties[i]
			if not seen[prop.name] then
				seen[prop.name] = true
				defs[#defs + 1] = prop
			end
		end
		current = classData.superclass
	end

	return defs
end

-- ---------------------------------------------------------------------------
-- Property normalization
-- ---------------------------------------------------------------------------

local function canonicalPropertyName(name)
	if name:match("^[A-Z]") then
		return name
	end
	return name:sub(1, 1):upper() .. name:sub(2)
end

local function isValidSerializedColor3(ser)
	return type(ser) == "table"
		and ser.__type == "Color3"
		and not ser._invalid
		and ser.r >= 0 and ser.r <= 1
		and ser.g >= 0 and ser.g <= 1
		and ser.b >= 0 and ser.b <= 1
end

local function isBetterPropertyValue(newVal, oldVal)
	if isValidSerializedColor3(newVal) and not isValidSerializedColor3(oldVal) then
		return true
	end
	if type(newVal) == "table" and newVal.__type and (not oldVal or oldVal == newVal) then
		return true
	end
	return false
end

local function dedupeProperties(props)
	local byLower = {}
	local result = {}

	for name, value in pairs(props) do
		local lower = name:lower()
		local existing = byLower[lower]

		if not existing then
			byLower[lower] = name
			result[name] = value
		else
			local keepNew = false
			if name:match("^[A-Z]") and not existing:match("^[A-Z]") then
				keepNew = true
			elseif isBetterPropertyValue(value, result[existing]) then
				keepNew = true
			end

			if keepNew then
				result[existing] = nil
				byLower[lower] = name
				result[name] = value
			end
		end
	end

	local uid = result.UniqueId
	if uid == "00000000-0000-0000-0000-000000000000"
		or (type(uid) == "string" and uid:match("^0%-0%-0%-0%-0+$")) then
		result.UniqueId = nil
	end

	return result
end

local function rereadColor3Property(obj, propName)
	for _, tryName in ipairs({ canonicalPropertyName(propName), propName, "Color3", "Color" }) do
		local ok, val = pcall(function()
			return obj[tryName]
		end)
		if ok and typeof(val) == "Color3" then
			local ser = serializeValue(val)
			if isValidSerializedColor3(ser) then
				return ser
			end
		end
	end
	return nil
end

