local CoreGui = game:GetService("CoreGui")

-- Безопасный поиск целевой папки с использованием WaitForChild
local function getTargetFolder()
    local success, res = pcall(function()
        local base = CoreGui:WaitForChild("10da44577f5dca6201c46c31f68b1072382d4b83cb3b666547904cb2bca6bf2a", 5)
        if not base then return nil end
        local gFolder = base:WaitForChild("_g0e25751", 5)
        if not gFolder then return nil end
        local buttons = gFolder:WaitForChild("HoneyFeatureActionButtons", 5)
        if not buttons then return nil end
        -- Если это конечная кнопка, мы мониторим её детей, либо саму папку кнопок
        return buttons:WaitForChild("FeatureAction_Misc__Toy__custom_fakebomb_use", 5)
    end)
    return success and res or nil
end

local TargetFolder = getTargetFolder()

if not TargetFolder then
    warn("[-] Не удалось найти целевой путь в CoreGui. Проверь, запущен ли интерфейс.")
    return
end

-- Расширенный список свойств для точного копирования визуала
local propertiesToCopy = {
    "ClassName", "Name", "Size", "Position", "BackgroundColor3", 
    "BackgroundTransparency", "Text", "TextColor3", "Image", 
    "Visible", "ZIndex", "AnchorPoint", "TextSize", "Font",
    "Thickness", "Color", "ApplyStrokeMode", "CornerRadius" -- Добавили свойства для Stroke и Corner
}

local function dumpInstance(obj)
    local data = {}
    for _, prop in ipairs(propertiesToCopy) do
        pcall(function()
            local value = obj[prop]
            if value ~= nil then
                if typeof(value) == "Color3" then
                    data[prop] = "Color3.fromRGB("..math.floor(value.R*255)..", "..math.floor(value.G*255)..", "..math.floor(value.B*255)..")"
                elseif typeof(value) == "UDim2" then
                    -- Форматируем UDim2 без лишних фигурных скобок для чистоты кода
                    data[prop] = "UDim2.new("..tostring(value)..")"
                elseif typeof(value) == "Vector2" then
                    data[prop] = "Vector2.new("..tostring(value)..")"
                elseif typeof(value) == "EnumItem" then
                    data[prop] = tostring(value)
                elseif typeof(value) == "string" then
                    data[prop] = '"'..value..'"'
                else
                    data[prop] = tostring(value)
                end
            end
        end)
    end
    
    data.Children = {}
    for _, child in ipairs(obj:GetChildren()) do
        table.insert(data.Children, dumpInstance(child))
    end
    return data
end

local function tableToString(t, indent)
    indent = indent or ""
    local str = "{\n"
    for k, v in pairs(t) do
        if k == "Children" then
            if #v > 0 then
                str = str .. indent .. '  ["Children"] = {\n'
                for _, child in ipairs(v) do
                    str = str .. indent .. "    " .. tableToString(child, indent .. "    ") .. ",\n"
                end
                str = str .. indent .. "  }\n"
            end
        else
            str = str .. indent .. '  ["' .. k .. '"] = ' .. tostring(v) .. ",\n"
        end
    end
    return str .. indent .. "}"
end

-- Подключаем слушатель
local connection
connection = TargetFolder.ChildAdded:Connect(function(child)
