    if not character then return nil end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end

    local old = hrp:FindFirstChild("CustomBubbleGui")
    if old then old:Destroy() end

    local bGui = Instance.new("BillboardGui")
    bGui.Name = "CustomBubbleGui"
    bGui.Adornee = hrp
    bGui.AlwaysOnTop = true
    bGui.LightInfluence = 0
    bGui.Size = UDim2.new(0, 240, 0, 300)
    -- StudsOffset = camera space: X всегда правее на экране, Y вверх, Z к камере
    -- не зависит от поворота персонажа
    bGui.StudsOffset = Vector3.new(4, 1.5, 0)
    bGui.ResetOnSpawn = false
    bGui.Parent = hrp

    local container = Instance.new("Frame")
