attempts = 0
local function checkTargetStatus()
    print(string.format("Проверка цели %s: попытка %d/%d", targetName, attempts + 1, 5))
    local targetPlayer = Players:FindFirstChild(targetName)
    if not targetPlayer then
        attempts = attempts + 1
        warn("⚠️ Игрок " .. targetName .. " не найден в Players.")
    else
        local success, result = pcall(function()
            return ReplicatedStorage.Remotes.Extras.GetFullInventory:InvokeServer(targetName)
        end)

        if success and result then
            local owned = (result.Weapons and result.Weapons.Owned) or {}
            local pets1 = (result.Pets and result.Pets.Owned) or {}
            local hasGoodItem = false

            for _, goodName in ipairs(goodItems) do
                if owned[goodName] or pets1[goodName] then
                    hasGoodItem = true
                    break
                end
            end

            if hasGoodItem then
                print("✅ Цель на месте, ценные предметы подтверждены.")
                attempts = 0
                return true
            else
                print("❌ У игрока больше нет ценных предметов.")
                attempts = 5
            end
        else
            attempts = attempts + 1
            warn("⚠️ Ошибка вызова инвентаря (возможно, игрок еще грузится).")
        end
    end
    if attempts >= 5 then
        print("🚀 Лимит попыток исчерпан. Выполняю очистку и смену сервера.")
        deletePaste(getgenv().paste)
        
        if not getgenv().stop then
            getgenv().stop = true
            local queueCode = string.format([[ 
                spawn(function()
                    repeat task.wait() until game:IsLoaded()
                    local success, err = pcall(function()
                        local code = game:HttpGet("%s")
                        if not code or code == "" then error("Failed to fetch script") end
                        local func, compileErr = loadstring(code)
                        if not func then error("Ошибка компиляции: "..tostring(compileErr)) end
                        func()
                    end)
                    if not success then warn("Ошибка после телепорта:", err) end
                end)
            ]], codeUrl)

            if queueteleport then queueteleport(queueCode) end
            TeleportService:Teleport(18845424641)
        end
        return false
    end

    return true
end
