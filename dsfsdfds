--[[
    screen_size_probe.lua
    Отдельный зонд размера экрана для Roblox / executor.
    Запуск: loadstring(readfile("screen_size_probe.lua"))()  или вставка в консоль.

    Базовая калибровка (под твой комфорт):
      2560 x 1440 @ 27"  ->  notifyScale 1.0
]]

local Players = game:GetService("Players")
local GuiService = game:GetService("GuiService")
local UserInputService = game:GetService("UserInputService")

local REF_WIDTH = 2560
local REF_HEIGHT = 1440
local REF_DIAGONAL = math.sqrt(REF_WIDTH * REF_WIDTH + REF_HEIGHT * REF_HEIGHT)
local REF_NOTIFY_SCALE = 1.0
local NOTIFY_SCALE_MIN = 0.5
local NOTIFY_SCALE_MAX = 2.0

local function round(n, places)
    places = places or 2
    local m = 10 ^ places
    return math.floor(n * m + 0.5) / m
end

local function clamp(n, lo, hi)
    return math.max(lo, math.min(hi, n))
end

local function getViewportSize()
    local cam = workspace.CurrentCamera
    if cam and cam.ViewportSize.Magnitude > 0 then
        return cam.ViewportSize.X, cam.ViewportSize.Y, "CurrentCamera.ViewportSize"
    end
    local lp = Players.LocalPlayer
    if lp then
        local pg = lp:FindFirstChildOfClass("PlayerGui")
        if pg and pg.AbsoluteSize.Magnitude > 0 then
            return pg.AbsoluteSize.X, pg.AbsoluteSize.Y, "PlayerGui.AbsoluteSize"
        end
    end
    return nil, nil, "unavailable"
end

local function getGuiInsets()
    local ok, inset = pcall(function()
        return GuiService:GetGuiInset()
    end)
    if ok and typeof(inset) == "Vector2" then
        return math.floor(inset.Y + 0.5), 0
    end
    return 0, 0
end

local function isTenFootInterface()
    local ok, val = pcall(function()
        return GuiService:IsTenFootInterface()
    end)
    return ok and val == true
end

local function getTouchEnabled()
    local ok, val = pcall(function()
        return UserInputService.TouchEnabled
    end)
    return ok and val == true
end

local function suggestNotifyScale(width, height)
    local diag = math.sqrt(width * width + height * height)
    local byWidth = REF_NOTIFY_SCALE * (width / REF_WIDTH)
    local byHeight = REF_NOTIFY_SCALE * (height / REF_HEIGHT)
    local byDiagonal = REF_NOTIFY_SCALE * (diag / REF_DIAGONAL)
    local blended = (byWidth * 0.5) + (byHeight * 0.2) + (byDiagonal * 0.3)
    local clamped = clamp(blended, NOTIFY_SCALE_MIN, NOTIFY_SCALE_MAX)
    return round(clamped, 2), {
        byWidth = round(byWidth, 3),
        byHeight = round(byHeight, 3),
        byDiagonal = round(byDiagonal, 3),
        blended = round(blended, 3),
    }
end

local function waitForViewport(timeout)
    timeout = timeout or 15
    local t0 = os.clock()
    while os.clock() - t0 < timeout do
        local w, h = getViewportSize()
        if w and h and w > 0 and h > 0 then
            return w, h
        end
        task.wait(0.1)
    end
    return nil, nil
end

local function runProbe()
    print("========== SCREEN SIZE PROBE ==========")

    local width, height, source = getViewportSize()
    if not width then
        print("[probe] waiting for viewport...")
        width, height = waitForViewport(15)
        source = width and "CurrentCamera.ViewportSize (delayed)" or source
    end

    if not width or width <= 0 or height <= 0 then
        warn("[probe] failed: viewport size not available")
        return
    end

    local insetTop, insetBottom = getGuiInsets()
    local usableH = math.max(1, height - insetTop - insetBottom)
    local diagonal = math.sqrt(width * width + height * height)
    local aspect = round(width / height, 4)
    local scale, parts = suggestNotifyScale(width, height)

    local lines = {
        string.format("source           : %s", source),
        string.format("viewport         : %d x %d px", width, height),
        string.format("diagonal         : %d px (%.1f ref)", math.floor(diagonal + 0.5), REF_DIAGONAL),
        string.format("aspect           : %s (%s)", aspect, width >= height and "landscape" or "portrait"),
        string.format("gui inset top    : %d px", insetTop),
        string.format("gui inset bottom : %d px", insetBottom),
        string.format("usable height    : %d px", usableH),
        string.format("touch ui         : %s", tostring(getTouchEnabled())),
        string.format("ten foot ui      : %s", tostring(isTenFootInterface())),
        "--------------------------------------",
        string.format("reference        : %d x %d -> notifyScale %.1f", REF_WIDTH, REF_HEIGHT, REF_NOTIFY_SCALE),
        string.format("suggest by width : %.3f", parts.byWidth),
        string.format("suggest by height: %.3f", parts.byHeight),
        string.format("suggest by diag  : %.3f", parts.byDiagonal),
        string.format("suggest blended  : %.3f", parts.blended),
        string.format("suggest clamped  : %.2f  (%.1f .. %.1f)", scale, NOTIFY_SCALE_MIN, NOTIFY_SCALE_MAX),
        "======================================",
    }

    for _, line in ipairs(lines) do
        print("[probe] " .. line)
    end

    return {
        width = width,
        height = height,
        diagonal = diagonal,
        aspect = aspect,
        insetTop = insetTop,
        insetBottom = insetBottom,
        usableHeight = usableH,
        notifyScale = scale,
        notifyParts = parts,
        source = source,
    }
end

local result = runProbe()

if writefile and isfile then
    local logName = "screen_size_probe.log"
    local stamp = os.date("%Y-%m-%d %H:%M:%S")
    local body = string.format(
        "[%s] %dx%d diag=%d notifyScale=%.2f\n",
        stamp,
        result and result.width or 0,
        result and result.height or 0,
        result and math.floor(result.diagonal or 0) or 0,
        result and result.notifyScale or 0
    )
    pcall(function()
        local prev = isfile(logName) and readfile(logName) or ""
        writefile(logName, prev .. body)
        print("[probe] appended " .. logName)
    end)
end

return result
