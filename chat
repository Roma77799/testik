local function updateScrollThumb()
    local canvasHeight = messageList.AbsoluteCanvasSize.Y
    local viewHeight   = messageList.AbsoluteWindowSize.Y
    local trackHeight  = scrollTrack.AbsoluteSize.Y
    if viewHeight <= 0 or trackHeight <= 0 or canvasHeight <= viewHeight then
        scrollTrack.Visible = false
        scrollThumb.Position = UDim2.fromOffset(0, 0)
        scrollThumb.Size = UDim2.new(1, 0, 1, 0)
        return
    end
    scrollTrack.Visible = true
    local thumbHeight = math.clamp(math.floor((viewHeight / canvasHeight) * trackHeight), 24, trackHeight)
    local maxCanvasY  = math.max(0, canvasHeight - viewHeight)
    local scrollRatio = maxCanvasY > 0 and (messageList.CanvasPosition.Y / maxCanvasY) or 0
    local maxThumbY   = math.max(0, trackHeight - thumbHeight)
    local thumbY      = math.floor(maxThumbY * math.clamp(scrollRatio, 0, 1))
    scrollThumb.Size     = UDim2.new(1, 0, 0, thumbHeight)
    scrollThumb.Position = UDim2.fromOffset(0, thumbY)
end

local function setScrollFromThumb(offsetY)
    local trackHeight  = scrollTrack.AbsoluteSize.Y
    local thumbHeight  = scrollThumb.AbsoluteSize.Y
    local canvasHeight = messageList.AbsoluteCanvasSize.Y
    local viewHeight   = messageList.AbsoluteWindowSize.Y
    local maxThumbY    = math.max(0, trackHeight - thumbHeight)
    local maxCanvasY   = math.max(0, canvasHeight - viewHeight)
    if maxThumbY <= 0 or maxCanvasY <= 0 then
        messageList.CanvasPosition = Vector2.new(0, 0)
        return
    end
    messageList.CanvasPosition = Vector2.new(0, math.floor(maxCanvasY * math.clamp(offsetY / maxThumbY, 0, 1)))
end

local function setContentTransparency(alpha)
    local isHiding = alpha == 1
    TweenService:Create(chatWindow, TweenInfo.new(0.4), {
        BackgroundTransparency = isHiding and 1 or 0.3
    }):Play()
    TweenService:Create(inputContainer, TweenInfo.new(0.4), {
        BackgroundTransparency = isHiding and 1 or 0.55
    }):Play()
    for _, child in ipairs(inputContainer:GetDescendants()) do
        if child:IsA("TextLabel") or child:IsA("TextBox") then
            TweenService:Create(child, TweenInfo.new(0.4), { TextTransparency = alpha }):Play()
        end
        if child:IsA("ImageLabel") then
            TweenService:Create(child, TweenInfo.new(0.4), { ImageTransparency = alpha }):Play()
        end
    end
    header.TextTransparency = 0
    TweenService:Create(closeButton, TweenInfo.new(0.4), { ImageTransparency = 0 }):Play()
end

local function resetActivityTimer()
