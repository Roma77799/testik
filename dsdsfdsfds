local function createButton(name, text, defaultX, defaultY, corner, callback)
    local controller = {}
    controller.sizeX = defaultX
    controller.sizeY = defaultY
    controller.connections = {}

    -- Services
    local TweenService = game:GetService("TweenService")
    local UserInputService = game:GetService("UserInputService")
    local RunService = game:GetService("RunService")
    local CoreGui = game:GetService("CoreGui")

    -- ScreenGui
    local sg = Instance.new("ScreenGui")
    sg.Name = name
    sg.Parent = CoreGui
    sg.ResetOnSpawn = false

    -- Button (минималистичный дизайн)
    local btn = Instance.new("TextButton")
    btn.Name = name .. "Btn"
    btn.Text = text
    btn.Size = UDim2.new(0, controller.sizeX, 0, controller.sizeY)
    btn.Position = UDim2.new(0, 20, 0, 20)
    btn.BackgroundColor3 = Color3.fromRGB(10, 6, 1)
    btn.BackgroundTransparency = 0.5
    btn.BorderSizePixel = 0
    btn.TextColor3 = Color3.fromRGB(221, 214, 197)
    btn.TextSize = 11
    btn.Font = Enum.Font.GothamBold
    btn.ZIndex = 41
    btn.AnchorPoint = Vector2.new(0, 0)
    btn.Parent = sg

    -- Скругление
    local uiCorner = Instance.new("UICorner")
    uiCorner.CornerRadius = UDim.new(0, 14)
    uiCorner.Name = "FeatureActionCorner"
    uiCorner.Parent = btn

    -- Обводка
    local border = Instance.new("UIStroke")
    border.Thickness = 0.8999999761581421
    border.Color = Color3.fromRGB(176, 113, 23)
    border.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    border.ZIndex = 1
    border.Name = "UIStroke"
    border.Parent = btn

    -- Звук клика
    local clickSound = Instance.new("Sound")
    clickSound.SoundId = "rbxassetid://6324790483"
    clickSound.Volume = 4
    clickSound.Parent = btn

    -- Drag vars (мультитач фикс)
    local dragging = false
    local dragStart
    local startOffset
    local activeInput = nil -- конкретный палец / мышь

    local function clampUDim2(udm)
        local s, sz = sg.AbsoluteSize, btn.AbsoluteSize
        return UDim2.fromOffset(
            math.clamp(udm.X.Offset, 0, s.X - sz.X),
            math.clamp(udm.Y.Offset, 0, s.Y - sz.Y)
        )
    end

    local function tweenTo(goal)
        TweenService:Create(
            btn,
            TweenInfo.new(0.23, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            { Position = goal }
        ):Play()
    end

    -- InputBegan
    table.insert(controller.connections,
        btn.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1
            or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                activeInput = input
                dragStart = input.Position
                startOffset = btn.Position
            end
        end)
    )

    -- InputEnded
    table.insert(controller.connections,
        UserInputService.InputEnded:Connect(function(input)
            if input == activeInput then
                dragging = false
                activeInput = nil
            end
        end)
    )

    -- InputChanged
    table.insert(controller.connections,
        UserInputService.InputChanged:Connect(function(input)
            if dragging
            and input == activeInput
            and (
                input.UserInputType == Enum.UserInputType.MouseMovement
                or input.UserInputType == Enum.UserInputType.Touch
            ) then
                local delta = input.Position - dragStart
                tweenTo(
                    clampUDim2(
                        UDim2.new(
                            0, startOffset.X.Offset + delta.X,
                            0, startOffset.Y.Offset + delta.Y
                        )
                    )
                )
            end
        end)
    )

    -- Анимация нажатия
    local baseSize = btn.Size
    local function pressAnimation(pressed)
        local scale = pressed and 0.95 or 1
        TweenService:Create(
            btn,
            TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {
                Size = UDim2.new(
                    0, baseSize.X.Offset * scale,
                    0, baseSize.Y.Offset * scale
                )
            }
        ):Play()

        if pressed then
            clickSound:Play()
        end
    end

    table.insert(controller.connections, btn.MouseButton1Down:Connect(function()
        pressAnimation(true)
    end))

    table.insert(controller.connections, btn.MouseButton1Up:Connect(function()
        pressAnimation(false)
    end))

    table.insert(controller.connections, btn.MouseLeave:Connect(function()
        pressAnimation(false)
    end))

    table.insert(controller.connections, btn.MouseButton1Click:Connect(function()
        if callback then
            callback()
        end
    end))

    -- API
    function controller:setSize(x, y)
        controller.sizeX = x
        controller.sizeY = y
        btn.Size = UDim2.new(0, x, 0, y)
        baseSize = btn.Size
    end

    function controller:setCorner(value)
        uiCorner.CornerRadius = UDim.new(0, value)
    end

    function controller:destroy()
        for _, con in ipairs(controller.connections) do
            if con and con.Disconnect then
                con:Disconnect()
            end
        end
        sg:Destroy()
    end

    return controller
end
