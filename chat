    UserInputService.InputChanged:Connect(function(input)
        if serverListDragging and (
            input.UserInputType == Enum.UserInputType.MouseMovement
            or (input.UserInputType == Enum.UserInputType.Touch and input == serverListDragActiveInput)
        ) then
            local d       = input.Position - serverListDragStart
            local viewport = workspace.CurrentCamera.ViewportSize
            local winSize  = serverListWindow.AbsoluteSize
            serverListWindow.AnchorPoint = Vector2.new(0, 0)
            serverListWindow.Position = UDim2.fromOffset(
                math.clamp(serverListDragWindowStart.X + d.X, 0, viewport.X - winSize.X),
                math.clamp(serverListDragWindowStart.Y + d.Y, 0, viewport.Y - winSize.Y)
            )
        end
        if slIsDraggingScrollThumb and (
            input.UserInputType == Enum.UserInputType.MouseMovement
            or (input.UserInputType == Enum.UserInputType.Touch and input == slScrollActiveInput)
        ) then
            slSetScrollFromThumb(slScrollThumbStartY + (input.Position.Y - slScrollThumbDragStart.Y))
        end
        if serverListResizing and (
            input.UserInputType == Enum.UserInputType.MouseMovement
            or (input.UserInputType == Enum.UserInputType.Touch and input == serverListResizeActiveInput)
        ) then
            local mousePos = input.Position
            local viewport = workspace.CurrentCamera.ViewportSize
            local winPos   = serverListWindow.AbsolutePosition
            serverListWindow.Size = UDim2.new(0,
                math.clamp(mousePos.X - winPos.X, 240, math.min(700, viewport.X - winPos.X)),
                0,
                math.clamp(mousePos.Y - winPos.Y, 140, math.min(600, viewport.Y - winPos.Y))
            )
            serverListLastSize = serverListWindow.Size
        end
    end)

