local function getTopServiceName(fullName)
	return fullName:match("^([^.]+)") or fullName
end

local function isUnderSystemRoot(fullName)
	local top = getTopServiceName(fullName)
	return SYSTEM_ROOTS[top] == true
end

function Exporter.getExportRoots()
	local cfg = Exporter.Config
	if not cfg.gameOnly then
		return { gameRoot }
	end

	local roots = {}
	local seen = {}

	local function addRoot(inst)
		if inst and not seen[inst] then
			seen[inst] = true
			roots[#roots + 1] = inst
		end
	end

	for _, name in ipairs(cfg.exportRoots or {}) do
		addRoot(gameRoot:FindFirstChild(name))
	end

	if cfg.includeLocalPlayer then
		local ok, plr = pcall(function()
			return game:GetService("Players").LocalPlayer
		end)
		if ok and plr then
			addRoot(plr:FindFirstChild("PlayerGui"))
			addRoot(plr:FindFirstChild("PlayerScripts"))
			addRoot(plr:FindFirstChild("Backpack"))
			addRoot(plr:FindFirstChild("leaderstats"))
			if plr.Character then
				addRoot(plr.Character)
			end
		end
	end

	if #roots == 0 then
		addRoot(gameRoot:FindFirstChild("Workspace"))
	end

	return roots
end

function Exporter.getExportRoot()
	local placeId = game.PlaceId
	local placeName = "Place"
	pcall(function()
		placeName = MarketplaceService:GetProductInfo(placeId).Name
	end)
	placeName = sanitizeSegment(placeName)
	local stamp = os.date("%Y-%m-%d_%H-%M-%S")
	if Exporter.Config.shortExportFolder then
		return pathJoin(Exporter.Config.rootFolder, ("%d_%s"):format(placeId, stamp))
	end
	return pathJoin(Exporter.Config.rootFolder, ("%d_%s_%s"):format(placeId, placeName, stamp))
end

function Exporter.gatherInstances()
	local list = {}
	local seen = {}
	local count = 0

	local function add(inst)
		if seen[inst] then
			return
		end
		seen[inst] = true
		if Exporter.shouldSkipInstance(inst) then
			return
		end
		count += 1
		list[count] = inst
	end

	Exporter._exportRoots = Exporter.getExportRoots()

	for _, root in ipairs(Exporter._exportRoots) do
		add(root)
		for _, desc in ipairs(root:GetDescendants()) do
			add(desc)
		end
	end

	if Exporter.Config.includeNilInstances and type(getnilinstances) == "function" then
		local ok, nilInsts = pcall(getnilinstances)
		if ok and type(nilInsts) == "table" then
			for _, inst in ipairs(nilInsts) do
				add(inst)
			end
		end
	end

	return list
end

function Exporter.shouldSkipInstance(obj)
	local cfg = Exporter.Config

	if cfg.skipOrphanInstances and Exporter.isOrphanInstance(obj) then
		return true
	end

	if cfg.skipDataModel and obj.ClassName == "DataModel" then
		return true
	end

	if cfg.skipEngineClasses and ENGINE_CLASSES[obj.ClassName] then
		return true
	end

	if cfg.exportMode == "logic" then
		if obj.Parent == gameRoot then
			return true
		end
		if not isLogicClass(obj.ClassName) then
			return true
		end
	end

	if not cfg.includeCorePackages then
		local ok, inCore = pcall(function()
			local CoreGui = game:GetService("CoreGui")
			local CorePackages = game:GetService("CorePackages")
			return obj:IsDescendantOf(CoreGui) or obj:IsDescendantOf(CorePackages)
		end)
		if ok and inCore then
			return true
		end
	end

	local fullName = ""
	pcall(function()
		fullName = obj:GetFullName()
	end)

	if not cfg.includeCorePackages and isUnderSystemRoot(fullName) then
		return true
	end

	if fullName:find("^CoreGui") or fullName:find("^CorePackages") then
		return true
	end

	if fullName:find("^CoreGui%.") or fullName:find("^Chat%.") then
		return true
	end

	return false
end

function Exporter.exportInstance(obj, exportRoot, index, classIndex, pathRegistry)
	local fullName = "?"
	local className = "Unknown"
	pcall(function()
		fullName = obj:GetFullName()
		className = obj.ClassName
	end)

	local baseRelative = getRelativePath(obj, fullName, index, className)
	local relativePath = resolveUniquePath(baseRelative, pathRegistry)
	local originalTreePath
	relativePath, originalTreePath = capRelativePath(relativePath, exportRoot, index, className)
	local treePath = pathJoin(exportRoot, "tree", relativePath .. ".json")
	local treeFile = pathJoin("tree", relativePath .. ".json")
	local classFolder = pathJoin(exportRoot, "by-class", sanitizeSegment(className))
	local classFile = pathJoin(classFolder, ("%04d_%s.json"):format(index, sanitizeSegment(obj.Name)))

	local properties, hiddenProperties, attributes, tags, propErrors = collectProperties(obj)

	local parentRef = nil
	pcall(function()
		local par = obj.Parent
		if par then
			parentRef = {
				className = par.ClassName,
				name = par.Name,
				fullName = par:GetFullName(),
			}
		end
	end)

	local children = nil
	if Exporter.Config.includeChildren then
		children = {}
		pcall(function()
			for _, child in ipairs(obj:GetChildren()) do
				children[#children + 1] = {
					name = child.Name,
					className = child.ClassName,
				}
			end
		end)
	end

	local record = {
		_index = index,
		className = className,
		name = obj.Name,
		fullName = fullName,
		treeFile = treeFile,
		parent = parentRef,
		properties = properties,
	}

	if children then record.children = children end
	if attributes then record.attributes = attributes end
	if tags then record.tags = tags end
	if hiddenProperties and next(hiddenProperties) then record.hiddenProperties = hiddenProperties end
	if propErrors and next(propErrors) then record.propertyErrors = propErrors end

	if originalTreePath then
		record.originalTreePath = originalTreePath
	end

	if obj:IsA("LuaSourceContainer") and Exporter.Config.decompileScripts then
		record.scriptSidecar = exportScriptSource(obj, exportRoot, relativePath)
	end

	local wrote, writeErr = writeJson(treePath, record)
	if not wrote then
		return nil, writeErr or "writeJson failed"
	end
	if Exporter.Config.exportByClass then
		writeJson(classFile, record)
	end

	classIndex[className] = (classIndex[className] or 0) + 1
	return record, classIndex
end

local function saveManifest(exportRoot, manifest, complete)
	manifest.status = complete and "complete" or "in_progress"
	manifest.exportedCount = manifest.totalInstances or 0
	if not Exporter.Config.saveManifestList then
		manifest.instances = nil
	end
	writeJson(pathJoin(exportRoot, "manifest.json"), manifest)
end

function Exporter.run(userConfig)
	if type(userConfig) == "table" then
		for k, v in pairs(userConfig) do
			Exporter.Config[k] = v
		end
	end

	if Exporter.Config.propertiesMode == "full" then
		loadApiDump()
	end

	local exportRoot = Exporter.getExportRoot()
	folderCache = {}
	ensureFolder(exportRoot)
	ensureFolder(pathJoin(exportRoot, "tree"))
	if Exporter.Config.exportByClass then
		ensureFolder(pathJoin(exportRoot, "by-class"))
	end
	if Exporter.Config.decompileScripts then
		ensureFolder(pathJoin(exportRoot, "scripts"))
	end
	if Exporter.Config.saveBytecode then
		ensureFolder(pathJoin(exportRoot, "bytecode"))
	end

	local indexPath = pathJoin(exportRoot, "index.tsv")
	local indexBuffer = {}
	local indexBatchSize = Exporter.Config.indexBatchSize or 5000

	local function flushIndexBuffer()
		if #indexBuffer == 0 then
			return
		end
		if appendfile then
			appendfile(indexPath, table.concat(indexBuffer))
		end
		table.clear(indexBuffer)
	end

	local function bufferIndexLine(line)
		if not Exporter.Config.saveInstanceIndex then
			return
		end
		indexBuffer[#indexBuffer + 1] = line
		if #indexBuffer >= indexBatchSize then
			flushIndexBuffer()
		end
	end

	if Exporter.Config.saveInstanceIndex then
		writefile(indexPath, "index\tclassName\tfullName\ttreeFile\n")
	end

	Exporter.setStatus("Collecting instances...")
	local instances = Exporter.gatherInstances()
	Exporter.setStatus(("Mode [%s]: %d objects. Exporting..."):format(
		Exporter.Config.exportMode or "full",
		#instances
	))

	local manifest = {
		placeId = game.PlaceId,
		exportedAt = os.date("!%Y-%m-%dT%H:%M:%SZ"),
		exportRoot = exportRoot,
		status = "in_progress",
		totalInstances = 0,
		totalPlanned = #instances,
		byClassName = {},
	}

	local classIndex = {}
	local pathRegistry = {}
	local exported = 0
	local failed = 0
	local lastFailReason = nil
	local manifestEvery = Exporter.Config.manifestSaveEvery or 2000
	local yieldEvery = Exporter.Config.yieldEvery or 0
	local warnEveryFailed = Exporter.Config.warnEveryFailed or 100

	saveManifest(exportRoot, manifest, false)

	for i, obj in ipairs(instances) do
		local ok, record, writeErr = pcall(Exporter.exportInstance, obj, exportRoot, i, classIndex, pathRegistry)
		if ok and record then
			exported += 1
			manifest.byClassName[record.className] = (manifest.byClassName[record.className] or 0) + 1

			if Exporter.Config.saveManifestList then
				manifest.instances = manifest.instances or {}
				manifest.instances[#manifest.instances + 1] = {
					index = i,
					className = record.className,
					fullName = record.fullName,
					treeFile = record.treeFile,
				}
			end

			if Exporter.Config.saveInstanceIndex then
				bufferIndexLine(string.format(
					"%d\t%s\t%s\t%s\n",
					i,
					record.className,
					record.fullName:gsub("\t", " "),
					record.treeFile
				))
			end
		else
			failed += 1
			lastFailReason = ok and writeErr or record
			if failed == 1 or failed % warnEveryFailed == 0 then
				warn(("[Exporter] Write failed (%d so far): %s"):format(failed, tostring(lastFailReason)))
			end
		end

		if manifestEvery > 0 and i % manifestEvery == 0 then
			manifest.totalInstances = exported
			manifest.failedCount = failed
			saveManifest(exportRoot, manifest, false)
		end

		if yieldEvery > 0 and i % yieldEvery == 0 then
			Exporter.setStatus(("Exporting %d / %d..."):format(i, #instances))
			task.wait()
		elseif i % 1000 == 0 then
			Exporter.setStatus(("Exporting %d / %d..."):format(i, #instances))
		end
	end

	manifest.totalInstances = exported
	manifest.failedCount = failed
	flushIndexBuffer()
	manifest.filters = {
		exportMode = Exporter.Config.exportMode,
		gameOnly = Exporter.Config.gameOnly,
		exportRoots = Exporter.Config.exportRoots,
		skipEngineClasses = Exporter.Config.skipEngineClasses,
		skipOrphanInstances = Exporter.Config.skipOrphanInstances,
		includeCorePackages = Exporter.Config.includeCorePackages,
		propertiesMode = Exporter.Config.propertiesMode,
		shortExportFolder = Exporter.Config.shortExportFolder,
		maxPathLength = Exporter.Config.maxPathLength,
	}
	saveManifest(exportRoot, manifest, true)

	if Exporter.Config.exportByClass then
		for className, classCount in pairs(classIndex) do
			writeJson(pathJoin(exportRoot, "by-class", sanitizeSegment(className), "_count.json"), {
				className = className,
				count = classCount,
			})
		end
	end

	if failed > 0 then
		Exporter.setStatus(("Done: %d ok, %d failed -> %s"):format(exported, failed, exportRoot))
	else
		Exporter.setStatus(("Done: %d instances -> %s"):format(exported, exportRoot))
	end
	return exportRoot, manifest
end

