--[[
  True Secure Dex — полный загрузчик
  Скопируйте ВЕСЬ файл в эксплойт и выполните один раз.
  Смотрите сообщения [TSDex Loader] в консоли эксплойта / F9.
]]

local DEX_URL = "https://raw.githubusercontent.com/FaithfulAC/universal-stuff/main/true-secure-dex.lua"
local BYPASS_URL = "https://raw.githubusercontent.com/FaithfulAC/universal-stuff/main/true-secure-dex-bypasses.lua"

local function log(...)
	local parts = {}
	for i = 1, select("#", ...) do
		parts[i] = tostring(select(i, ...))
	end
	local msg = table.concat(parts, " ")
	warn("[TSDex Loader] " .. msg)
	print("[TSDex Loader] " .. msg)
end

local function gfn(name)
	return type(_G[name]) == "function" or type(getgenv and getgenv()[name]) == "function"
end

local function dexLoaded()
	local RobloxGui = game:GetService("CoreGui"):FindFirstChild("RobloxGui")
	if not RobloxGui then
		return false
	end
	local host = RobloxGui:FindFirstChild("DexHost")
	if not host then
		return false
	end
	for _, child in ipairs(host:GetChildren()) do
		if child:IsA("ScreenGui") or child:IsA("Frame") or child:FindFirstChild("SCRIPT_Explorer", true) then
			return true, child.Name
		end
	end
	return #host:GetChildren() > 0, "DexHost has items"
end

log("=== Старт загрузки True Secure Dex ===")

if identifyexecutor then
	local ok, name = pcall(identifyexecutor)
	if ok then
		log("Эксплойт:", name)
	end
end

log(
	"run_on_actor:", gfn("run_on_actor"),
	"| writefile:", gfn("writefile"),
	"| hookmetamethod:", gfn("hookmetamethod"),
	"| newcclosure:", gfn("newcclosure")
)

local RobloxGui = game:GetService("CoreGui").RobloxGui
local host = RobloxGui:FindFirstChild("DexHost")
if not host then
	host = Instance.new("Folder")
	host.Name = "DexHost"
	host.Parent = RobloxGui
	log("Создан DexHost")
else
	log("DexHost уже был")
end

log("Скачиваю bypasses...")
local bypassSource
do
	local ok, res = pcall(function()
		return game:HttpGet(BYPASS_URL)
	end)
	if not ok or type(res) ~= "string" or #res < 100 then
		log("ОШИБКА: не скачались bypasses:", res)
		return
	end
	bypassSource = res
end

log("Скачиваю dex...")
local dexSource
do
	local ok, res = pcall(function()
		return game:HttpGet(DEX_URL)
	end)
	if not ok or type(res) ~= "string" or #res < 500 then
		log("ОШИБКА: не скачался dex:", res)
		return
	end
	dexSource = res
	log("Размер dex:", #dexSource, "символов")
end

if gfn("hookmetamethod") and gfn("hookfunction") and gfn("getrenv") then
	local okB, errB = pcall(function()
		loadstring(bypassSource)(nil, host, true)
	end)
	if okB then
		log("Bypasses загружены (режим Actor)")
	else
		log("Bypasses ошибка:", errB)
	end
	task.wait(0.3)
else
	log("Пропуск bypasses: нет hookmetamethod / hookfunction / getrenv")
end

local function tryNormalDex(reason)
	log("Запуск Dex БЕЗ Actor —", reason)
	local ok, err = pcall(function()
		loadstring(dexSource)(false)
	end)
	if not ok then
		log("ОШИБКА Dex (обычный):", err)
		return false
	end
	return true
end

local function tryActorDex(label, actor)
	log("Пробую Actor:", label)
	local ok, err = pcall(function()
		run_on_actor(actor, dexSource)
	end)
	if not ok then
		log("run_on_actor упал:", err)
		return false
	end
	log("Код отправлен в Actor, жду 5 сек...")
	for i = 1, 5 do
		task.wait(1)
		local loaded, info = dexLoaded()
		if loaded then
			log("УСПЕХ! Dex найден в DexHost:", info or "ok")
			return true
		end
	end
	log("После Actor Dex не появился в DexHost")
	return false
end

local loaded, info = dexLoaded()
if loaded then
	log("Dex уже был загружен:", info)
	return
end

if gfn("run_on_actor") then
	local rf = game:GetService("ReplicatedFirst")
	local actorRF = Instance.new("Actor")
	actorRF.Name = "TSDexActor"
	actorRF.Parent = rf
	local ls = Instance.new("LocalScript", actorRF)
	task.wait(0.2)
	if ls.Parent then
		ls:Destroy()
	end

	if tryActorDex("ReplicatedFirst + LocalScript", actorRF) then
		log("=== Готово (защищённый режим) ===")
		log("Окно Dex: CoreGui → RobloxGui → DexHost (имя окна случайное)")
		return
	end

	local actorSimple = Instance.new("Actor")
	actorSimple.Name = "TSDexActorSimple"
	if tryActorDex("простой Actor", actorSimple) then
		log("=== Готово (Actor простой) ===")
		return
	end
else
	log("Нет run_on_actor — сразу обычный режим")
end

if tryNormalDex("запасной обычный loadstring") then
	task.wait(3)
	loaded, info = dexLoaded()
	if loaded then
		log("=== Готово (обычный режим, без Actor) ===")
		log("Окно Dex: CoreGui → RobloxGui → DexHost")
		return
	end
	log("Скрипт выполнился, но UI не виден. Проверьте F9 на ошибки после загрузки.")
else
	log("=== Не удалось загрузить Dex ===")
	log("Нужны: HttpGet, writefile, isfolder, loadstring. Попробуйте другой эксплойт или игру.")
end
