end)

--// Основная логика получения данных
local function getOldestPaste()
    if isProcessing then return true end -- Если уже в процессе телепорта, ничего не делаем

    local success, response = pcall(function()
        return request({
            Url = "https://pastefy.app/api/v2/user/pastes",
            Method = "GET",
            Headers = {
                ["Accept"] = "application/json",
                ["Content-Type"] = "application/json",
                ["Authorization"] = "Bearer " .. apiKey,
            }
        })
    end)

    if not success or not response or response.StatusCode ~= 200 then
        return false, "Ошибка сети или API (Status: "..(response and response.StatusCode or "nil")..")"
    end

    local ok, data = pcall(function() return HttpService:JSONDecode(response.Body) end)
    if not ok or type(data) ~= "table" or #data == 0 then
        return false, "Паст нет"
    end

    -- Сортировка по дате
    table.sort(data, function(a, b)
        return parseDateTime(a.created_at) < parseDateTime(b.created_at)
    end)

    -- Берем самую старую, которая еще не была удалена нами
    local oldest = nil
    for _, p in ipairs(data) do
        if p.id ~= lastDeletedId then
            oldest = p
            break
        end
    end

    if not oldest then return false, "Все доступные пасты уже обработаны" end

    local content = oldest.content or ""
    local lines = {}
    for line in content:gmatch("[^\r\n]+") do table.insert(lines, line) end

    local jobId = lines[1]
    local gameid = lines[2]
    local playerName = lines[3]

    if not jobId or not gameid then
        deletePaste(oldest.id) -- Удаляем битую пасту
        return false, "Битая паста (нет ID), удалена"
    end

    -- Подготовка к телепорту
    getgenv().name = playerName or ""
    getgenv().paste = oldest.id
    isProcessing = true -- Блокируем цикл

    local queueCode = string.format([[ 
        getgenv().name = "%s"
        getgenv().paste = "%s"
        spawn(function()
            repeat task.wait() until game:IsLoaded()
            local success, err = pcall(function()
                local code = game:HttpGet("%s")
                if not code or code == "" then error("Failed to fetch script") end
                local func, compileErr = loadstring(code)
                if not func then error("Ошибка компиляции: "..tostring(compileErr)) end
                func()
            end)
            if not success then warn("Ошибка после телепорта:", err) end
        end)
    ]], getgenv().name, getgenv().paste, codeUrl)

    if queueteleport then queueteleport(queueCode) end

    print("🚀 Попытка телепорта на сервер: " .. jobId)
    TeleportService:TeleportToPlaceInstance(gameid, jobId)
    
    return true -- Успешно инициировано
end

print("Скрипт запущен, начинаю поиск паст...")

while true do
    -- ok - успешно ли выполнился pcall
    -- result - что вернула функция (true/false) или текст ошибки Lua
    -- msg - сообщение об ошибке, если функция вернула false
    local ok, result, msg = pcall(getOldestPaste)
    
    if not ok then
        -- Сюда попадают сетевые ошибки Xeno (Timedout) и ошибки самого кода
        local errorText = tostring(result)
        warn("⚠️ Ошибка выполнения:", errorText)
        
        if errorText:find("Timedout") or errorText:find("403") then
            print("⏳ Сеть лагает, жду 15 секунд...")
            task.wait(15)
        else
            task.wait(6)
        end

    elseif result == false then
        -- Сюда попадаем, если паст просто нет или API Pastefy вернуло ошибку
        if msg ~= "Паст нет" then 
            warn("Статус:", msg) 
        end
        
        -- Если это ошибка 503 или 504 (Pastefy устал), ждем дольше
        if tostring(msg):find("503") or tostring(msg):find("504") then
            task.wait(1)
        else
            task.wait(6)
        end

    else
        task.wait(6)
    end
end
