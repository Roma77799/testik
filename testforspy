-- Simple Http request spy (No UI version)

local DEBUG = false

--// Libraries
local Hook = {}
local Http = {}

local HttpService = game:GetService("HttpService")

--// Globals
local GlobalENV = getgenv()
local Typeof = typeof

--// Config
local UrlIntercepts = {
    ["http://127.0.0.1:6463/rpc?v=1"] = {
        Callback = function()
            warn("[Spy] Blocked discord invite!")
            return ""
        end,
    },
}

--// Logging function (Заменяет UI консоль)
local function Log(...)
    local args = {...}
    local message = ""
    for i, v in ipairs(args) do
        message = message .. tostring(v) .. " "
    end
    print("[HTTP SPY]: " .. message)
end

--// Add Hooks Configuration
local function AddHooks()
    Hook:AddRefernce(game, {
        Globals = {"game", "Game"},
        Hooks = {
            ["HttpGet"] = "HTTP_HOOK",
            ["HttpGetAsync"] = "HTTP_HOOK",
            ["HttpPost"] = "HTTP_HOOK",
            ["HttpPostAsync"] = "HTTP_HOOK"
        }
    })

    Hook:AddRefernce(GlobalENV, {
        Hooks = {
            ["http_request"] = "HTTP_HOOK",
            ["request"] = "HTTP_HOOK",
        }
    })

    -- Проверка наличия библиотек перед хуком
    if http then
        Hook:AddRefernce(http, {
            Hooks = { ["request"] = "HTTP_HOOK" }
        })
    end

    if syn then
        Hook:AddRefernce(syn, {
            Hooks = { ["request"] = "HTTP_HOOK" }
        })
    end
end

--// HTTP detection logic
type ScanRequest = {
    Url: string,
    Body: (string|nil),
    IsPost: boolean?,
    IsTable: boolean?,
}

function Http:ScanHTTPRequest(Args: {}): ScanRequest
    local Request = {}
    for Index: number, Arg in next, Args do
        if Typeof(Arg) == "string" then
            Request.Url = Arg
            if not DEBUG then break end
        elseif Typeof(Arg) == "table" then
            local Url = Arg.Url or Arg.url
            if not Url then continue end
            local Body = Arg.Body or Arg.body
            Request.Url = Url
            Request.Body = Body
            Request.IsPost = Body and true or false
            Request.IsTable = true
            Request.Headers = Arg.Headers
            if not DEBUG then break end
        end
    end
    return Request
end

function Http:FindIntercept(Url: string)
    for UrlMatch, Data in next, UrlIntercepts do
        if Url:match(UrlMatch) then 
            warn(`[Spy] Matched intercept for: {Url}`)
            return Data 
        end
    end
    return nil
end

local function HttpCallback(OldFunc, ...)
    local Args = {...}
    local Request = Http:ScanHTTPRequest(Args)
    
    if not Request or not Request.Url then 
        return OldFunc(...) 
    end

    local IsPost = Request.IsPost
    local Url = Request.Url
    local Body = Request.Body
    local Headers = Request.Headers

    -- Логирование в консоль
    Log(`[{IsPost and "POST" or "GET"}]`, Url)

    if Body then
        Log("> [Body]", Body)
    end
    
    if Headers then
        local success, result = pcall(function() return HttpService:JSONEncode(Headers) end)
        Log("> [Headers]", success and result or "Failed to encode headers")
    end

    local Responce = nil
    local Intercept = Http:FindIntercept(Url)

    if not Intercept or Intercept.PassResponce then
        Responce = OldFunc(...)
    end

    if not Intercept then return Responce end

    local Spoofed = Intercept.Callback
    if Typeof(Spoofed) == "function" then
        Spoofed = Intercept.PassResponce and Spoofed(Responce, Request) or Spoofed(Request)
    end

    if Request.IsTable then
        local Base = Responce or {}
        return Hook:Hook(Base, { ["Body"] = Spoofed })
    end

    return Spoofed
end

--// Hook engine
function Hook:AddRefernce(Instance, Hooks)
    if not Instance then return end
    self.Hooks = self.Hooks or {}
    self.Hooks[Instance] = Hooks
end

Hook.Cache = setmetatable({}, {__mode = "k"})
Hook.Alliases = { ["HTTP_HOOK"] = HttpCallback }

function Hook:Hook(Object, Hooks)
    if self.Cache[Object] then return self.Cache[Object] end
    
    local Proxy = newproxy(true)
    local Meta = getmetatable(Proxy)

    Meta.__index = function(self, Key)
        if Hooks[Key] then return Hooks[Key] end
        local Value = Object[Key]
        if type(Value) == "function" then
            return function(_, ...) return Value(Object, ...) end
        end
        return Value
    end
    
    Meta.__newindex = function(_, Key, New) Object[Key] = New end
    Meta.__tostring = function() return tostring(Object) end
    self.Cache[Object] = Proxy
    return Proxy
end

function Hook:ApplyHooks()
    for Object, Data in next, self.Hooks do
        -- Проверка: если объект вообще существует
        if not Object then continue end

        local Hooks = Data.Hooks
        local IsReadOnly = false
        
        if type(Object) == "table" then
            IsReadOnly = table.isfrozen(Object)
        elseif type(Object) == "userdata" then
            -- Для защиты от ошибки "not a valid member" при проверке ReadOnly у Instance
            IsReadOnly = false 
        end
        
        if IsReadOnly then 
            pcall(setreadonly, Object, false) 
        end

        for Key, Value in next, Hooks do
            -- Используем pcall, чтобы скрипт не падал, если метода не существует
            local success, OldValue = pcall(function()
                return Object[Key]
            end)

            if not success or OldValue == nil then 
                -- Если метода (например HttpGet) нет в этом окружении, просто пропускаем его
                continue 
            end
            
            if typeof(Value) == "string" and self.Alliases[Value] then
                local Callback = self.Alliases[Value]
                
                -- Безопасная перезапись
                pcall(function()
                    Object[Key] = function(...) 
                        return Callback(OldValue, ...) 
                    end
                end)
            end
        end

        if Data.Globals then
            for _, Global in next, Data.Globals do
                -- Proxy создаем только если Object валиден
                local proxySuccess, Proxy = pcall(function() return self:Hook(Object, Hooks) end)
                if proxySuccess then
                    GlobalENV[Global] = Proxy
                end
            end
        end

        if IsReadOnly then 
            pcall(setreadonly, Object, true) 
        end
    end
end

--// Init
AddHooks()
Hook:ApplyHooks()

Log("Loaded successfully! Monitoring requests...")
