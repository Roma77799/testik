local PREFIX = "[SkinHarvester]"

local Players     = game:GetService("Players")
local HttpService = game:GetService("HttpService")
local RS          = game:GetService("ReplicatedStorage")

local plr = Players.LocalPlayer
local Weapons = (require(RS:WaitForChild("Database"):WaitForChild("Sync"))).Weapons
local EquipRemote = RS:WaitForChild("Remotes"):WaitForChild("Inventory"):WaitForChild("Equip")

local ProfileData
pcall(function()
    ProfileData = require(RS:WaitForChild("Modules"):WaitForChild("ProfileData"))
end)

local function ownsWeapon(dataId)
    if not CONFIG.skipUnowned or not ProfileData then return true end
    local owned = ProfileData.Weapons and ProfileData.Weapons.Owned
    if not owned then return true end
    local n = owned[dataId]
    return type(n) == "number" and n > 0
end

local DEFAULT_KNIFE_MESH = "121944778"
local DEFAULT_GUN_MESH   = "79401392"
local DEFAULT_TEXTURES   = { "121944805", "91723031" }

local function log(...) print(PREFIX, ...) end
local function warnLog(...) warn(PREFIX, ...) end

local function vec3ToArr(v)
    if typeof(v) == "Vector3" then return { v.X, v.Y, v.Z } end
    if type(v) == "table" then return { v[1] or 0, v[2] or 0, v[3] or 0 } end
    return { 0, 0, 0 }
end

local function normId(url)
    if not url or url == "" then return "" end
    local s = tostring(url)
    local id = s:match("(%d+)%s*$") or s:match("(%d+)")
    return id or s
end

local function syncOffset(itemInfo)
    local o = itemInfo and itemInfo.Offset
    if not o then return nil end
    return { o.X or 0, o.Y or 0, o.Z or 0 }
end

local function isDefaultTexture(texId)
    if not texId or texId == "" then return true end
    local s = tostring(texId)
    for _, id in ipairs(DEFAULT_TEXTURES) do
        if s:find(id, 1, true) then return true end
    end
    return false
end

local function isCustomMesh(meshId, weaponType)
    if not meshId or meshId == "" then return false end
    local s = tostring(meshId)
    if weaponType == "Knife" then return not s:find(DEFAULT_KNIFE_MESH, 1, true) end
    return not s:find(DEFAULT_GUN_MESH, 1, true)
end

local function isChromaRelated(idA, idB)
    if idA == idB then return true end
    if idA:sub(-6) == "Chroma" and idA:sub(1, -7) == idB then return true end
    if idB:sub(-6) == "Chroma" and idB:sub(1, -7) == idA then return true end
    if idA:sub(1, 6) == "Chroma" and idA:sub(7) == idB then return true end
    if idB:sub(1, 6) == "Chroma" and idB:sub(7) == idA then return true end
    return false
end

local queue = {}

local function buildQueue()
    local list = {}
    for _, tier in ipairs(TIER_ORDER) do
        for _, dataId in ipairs(SKINS[tier] or {}) do
            local info = Weapons[dataId]
            if info and (info.ItemType == "Knife" or info.ItemType == "Gun") then
                table.insert(list, { dataId = dataId, tier = tier })
            else
                warnLog("пропуск:", dataId)
            end
        end
    end
    return list
end

local function tierToRarity(tier)
    return ({ unique = "Unique", ancient = "Ancient", vintage = "Vintage", godly = "Godly" })[tier] or "Unknown"
end

local function getDisplayPart(weaponType)
    local char = plr.Character
    if not char then return nil end
    local ref = char:FindFirstChild(weaponType == "Knife" and "DisplayRefKnife" or "DisplayRefGun")
    if ref and ref:IsA("ObjectValue") and ref.Value then return ref.Value end
    return nil
end

local function findDisplayMesh(part)
    if not part then return nil, nil end
    if part:IsA("MeshPart") then return part, "MeshPart" end
    local direct = part:FindFirstChildOfClass("SpecialMesh") or part:FindFirstChildWhichIsA("DataModelMesh")
    if direct then return direct, direct.ClassName end
    for _, desc in ipairs(part:GetDescendants()) do
        if desc:IsA("SpecialMesh") or desc:IsA("FileMesh") then
            return desc, desc.ClassName
        end
        if desc:IsA("MeshPart") then
            return desc, "MeshPart"
        end
    end
    return nil, nil
end

local function readDisplaySignature(part)
    if not part then return "" end
    local mesh, kind = findDisplayMesh(part)
    if not mesh then return "" end
    if kind == "MeshPart" then
        return string.format("MP|%s|%s", normId(mesh.MeshId), normId(mesh.TextureID))
    end
    return string.format("SM|%s|%s", normId(mesh.MeshId), normId(mesh.TextureId))
end

local function equipWeapon(dataId)
    EquipRemote:FireServer(dataId, "Weapons")
    if ProfileData and ProfileData.Weapons and ProfileData.Weapons.Equipped then
        local info = Weapons[dataId]
        if info and info.ItemType == "Knife" then
            ProfileData.Weapons.Equipped.Knife = dataId
        elseif info and info.ItemType == "Gun" then
            ProfileData.Weapons.Equipped.Gun = dataId
        end
    end
end

local function getEquippedId(weaponType)
    if not ProfileData or not ProfileData.Weapons or not ProfileData.Weapons.Equipped then
        return nil
    end
    return weaponType == "Knife" and ProfileData.Weapons.Equipped.Knife or ProfileData.Weapons.Equipped.Gun
end

local function waitForEquipped(weaponType, dataId, timeout)
    local deadline = os.clock() + timeout
    while os.clock() < deadline do
        if getEquippedId(weaponType) == dataId then
            return true
        end
        task.wait(0.05)
    end
    return false
end

local function waitForDefaultDisplay(weaponType)
    local defaultMesh = weaponType == "Knife" and DEFAULT_KNIFE_MESH or DEFAULT_GUN_MESH
    local deadline = os.clock() + CONFIG.resetTimeout
    while os.clock() < deadline do
        local part = getDisplayPart(weaponType)
        local sig = readDisplaySignature(part)
        if sig ~= "" and sig:find(defaultMesh, 1, true) then
            return part, sig
        end
        task.wait(0.05)
    end
    local part = getDisplayPart(weaponType)
    return part, readDisplaySignature(part)
end

local function resetToDefault(weaponType)
    local defaultId = weaponType == "Knife" and "DefaultKnife" or "DefaultGun"
    equipWeapon(defaultId)
    waitForEquipped(weaponType, defaultId, CONFIG.resetTimeout)
    local part, sig = waitForDefaultDisplay(weaponType)
    task.wait(0.15)
    return part, sig
end

-- Must be declared before helpers that iterate it.
local sigOwners = {}

local function canAcceptUnchangedSig(dataId, sig)
    for ownerId, ownerSig in pairs(sigOwners) do
        if ownerSig == sig and isChromaRelated(dataId, ownerId) then
            return true
        end
    end
    return false
end

local function waitForDisplayAfterEquip(weaponType, sigBefore, dataId)
    local deadline = os.clock() + CONFIG.displayTimeout
    local settleAt = os.clock() + CONFIG.settleDelay
    while os.clock() < deadline do
        local part = getDisplayPart(weaponType)
        local sig = readDisplaySignature(part)
        if sig ~= "" then
            if sig ~= sigBefore then
                return part, sig
            end
            if os.clock() >= settleAt and canAcceptUnchangedSig(dataId, sig) then
                return part, sig
            end
        end
        task.wait(0.05)
    end
    return nil, nil
end

local function captureFromPart(part, dataId, itemInfo, tier)
    if not part then return nil end
    local weaponType = itemInfo.ItemType
    local entry = {
        DataID = dataId,
        Name = itemInfo.ItemName or dataId,
        Type = weaponType,
        ItemID = itemInfo.ItemID,
        Rarity = itemInfo.Rarity or tierToRarity(tier),
        Source = "harvester:" .. plr.Name,
        Tier = tier,
    }

    if itemInfo.Chroma == true then entry.Chroma = true end
    if itemInfo.FX == true then entry.FX = true end

    local offset = syncOffset(itemInfo)
    if offset then entry.Offset = offset end

    local mesh, kind = findDisplayMesh(part)
    if not mesh then return nil end

    if kind == "MeshPart" then
        entry.Kind = "MeshPart"
        entry.MeshId = mesh.MeshId
        entry.TextureId = mesh.TextureID
        entry.Scale = vec3ToArr(mesh.Size)
    else
        entry.Kind = mesh.ClassName
        entry.MeshId = mesh.MeshId
        entry.TextureId = mesh.TextureId
        entry.Scale = vec3ToArr(mesh.Scale)
        if mesh:IsA("SpecialMesh") then
            entry.Offset = vec3ToArr(mesh.Offset)
            entry.VertexColor = vec3ToArr(mesh.VertexColor)
        end
    end

    if isDefaultTexture(entry.TextureId) and not entry.MeshId then return nil end
    entry.IsCustomMesh = isCustomMesh(entry.MeshId, weaponType)
    entry.HasHandData = true
    entry.HandMesh = entry.MeshId
    entry.HandTexture = entry.TextureId
    entry.HandScale = entry.Scale
    entry.HandKind = entry.Kind
    entry.HandOffset = entry.Offset
    entry.HandVertexColor = entry.VertexColor
    return entry
end

local cache = {}

local function loadCache()
    if not readfile or not isfile or not isfile(CONFIG.outputFile) then return end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(CONFIG.outputFile)) end)
    if not ok or type(data) ~= "table" then return end
    for _, item in ipairs(queue) do
        local entry = data[item.dataId]
        if type(entry) == "table" then
            cache[item.dataId] = entry
        end
    end
end

local function saveCache()
    if not writefile then return end
    local out = {}
    for _, item in ipairs(queue) do
        local entry = cache[item.dataId]
        if entry then out[item.dataId] = entry end
    end
    pcall(function() writefile(CONFIG.outputFile, HttpService:JSONEncode(out)) end)
end

local function entrySignature(entry)
    if not entry then return "" end
    return string.format("%s|%s", normId(entry.MeshId or entry.HandMesh), normId(entry.TextureId or entry.HandTexture))
end

local function isValidCacheEntry(dataId, entry, itemInfo)
    if type(entry) ~= "table" then return false end
    local tex = entry.TextureId or entry.HandTexture
    local mesh = entry.MeshId or entry.HandMesh
    if (not mesh or mesh == "") and (not tex or tex == "" or isDefaultTexture(tex)) then
        return false
    end
    if itemInfo.Chroma == true and entry.Chroma ~= true then return false end
    local sig = entrySignature(entry)
    for ownerId, ownerSig in pairs(sigOwners) do
        if ownerSig == sig and ownerId ~= dataId and not isChromaRelated(dataId, ownerId) then
            return false
        end
    end
    return true
end

local function registerSignature(dataId, entry)
    sigOwners[dataId] = entrySignature(entry)
end

local function rebuildSigOwners()
    sigOwners = {}
    for id, entry in pairs(cache) do
        registerSignature(id, entry)
    end
end

local function isDuplicateCapture(dataId, sig, itemInfo)
    for ownerId, ownerSig in pairs(sigOwners) do
        if ownerSig == sig and ownerId ~= dataId and not isChromaRelated(dataId, ownerId) then
            return true, ownerId
        end
    end
    if not itemInfo.Chroma and sigOwners[dataId] == sig then
        return true, dataId
    end
    return false, nil
end

local function tryHarvest(dataId, itemInfo, tier, index, total)
    local weaponType = itemInfo.ItemType
    local lastReason = "неизвестно"
    for attempt = 1, CONFIG.maxAttempts do
        if attempt > 1 then
            log(string.format("[%d/%d] retry %s (%d/%d) — %s", index, total, dataId, attempt, CONFIG.maxAttempts, lastReason))
        end

        local _, defaultSig = resetToDefault(weaponType)
        defaultSig = defaultSig or ""

        equipWeapon(dataId)
        waitForEquipped(weaponType, dataId, CONFIG.displayTimeout)
        task.wait(CONFIG.equipCooldown)

        local part, sig = waitForDisplayAfterEquip(weaponType, defaultSig, dataId)
        local entry = nil
        if not part or not sig then
            local stuckSig = readDisplaySignature(getDisplayPart(weaponType))
            local meshId = stuckSig:match("|(%d+)|") or stuckSig:match("|(%d+)$") or "?"
            lastReason = string.format("дисплей не сменился (mesh %s, equipped=%s)", meshId, tostring(getEquippedId(weaponType)))
        else
            local dup, owner = isDuplicateCapture(dataId, sig, itemInfo)
            if dup then
                lastReason = "дубликат сигнатуры с " .. tostring(owner)
            else
                entry = captureFromPart(part, dataId, itemInfo, tier)
                if not entry then
                    lastReason = "не удалось прочитать mesh с дисплея"
                end
            end
        end

        if entry then
            return entry, attempt, nil
        end

        if attempt < CONFIG.maxAttempts then
            task.wait(CONFIG.retryDelay)
        end
    end
    return nil, CONFIG.maxAttempts, lastReason
end

-- ── main ───────────────────────────────────────────────────────────────────────

queue = buildQueue()
loadCache()
rebuildSigOwners()

log("Старт:", #queue, "скинов →", CONFIG.outputFile)

local captured, skipped, failed = 0, 0, 0
local lastWeaponType = nil

for i, item in ipairs(queue) do
    local dataId, tier = item.dataId, item.tier
    local itemInfo = Weapons[dataId]

    if CONFIG.resetOnTypeSwitch and lastWeaponType and lastWeaponType ~= itemInfo.ItemType then
        resetToDefault(itemInfo.ItemType)
    end
    lastWeaponType = itemInfo.ItemType

    if CONFIG.skipExisting and isValidCacheEntry(dataId, cache[dataId], itemInfo) then
        skipped += 1
    elseif not ownsWeapon(dataId) then
        failed += 1
        warnLog(string.format("[%d/%d] SKIP %s — нет в инвентаре", i, #queue, dataId))
    else
        cache[dataId] = nil
        sigOwners[dataId] = nil

        local entry, attempts, failReason = tryHarvest(dataId, itemInfo, tier, i, #queue)
        if entry then
            cache[dataId] = entry
            registerSignature(dataId, entry)
            captured += 1
            saveCache()
            local tryNote = attempts > 1 and (" x" .. attempts) or ""
            log(string.format("[%d/%d] OK %s [%s]%s", i, #queue, dataId, entry.Type, tryNote))
        else
            failed += 1
            warnLog(string.format("[%d/%d] FAIL %s (%d попыток) — %s", i, #queue, dataId, attempts, failReason or "?"))
        end
    end
end

saveCache()
log(string.format("Готово: +%d skip %d fail %d (в файле %d) → %s",
    captured, skipped, failed,
    (function() local n = 0 for _, item in ipairs(queue) do if cache[item.dataId] then n += 1 end end return n end)(),
    CONFIG.outputFile))
