    local wsAttempt = 0

    local function wsConnect()
        -- закрываем старое подключение если оно ещё живо
        if ws then
            pcall(function() ws:Close() end)
            ws = nil
            wsConnected = false
        end

        local ok, result = pcall(function()
            return WebSocket.connect("ws://92.246.139.177:1001")
        end)
        if not ok then
            wsAttempt = wsAttempt + 1
            warn("ChatService: connect failed:", result)
            addMessage("System", "[attempt " .. wsAttempt .. "] Unable to connect. Retry in 5s...", Color3.fromRGB(255, 80, 80))
            task.delay(5, wsConnect)
            return
        end
        wsAttempt = 0

        ws = result
        wsConnected = true

        ws:Send(HttpService:JSONEncode({
            type   = "register",
            jobId  = getgenv().haha,
            name   = LocalPlayer.Name,
            userId = LocalPlayer.UserId,
        }))

        ws.OnMessage:Connect(function(raw)
            local ok2, data = pcall(HttpService.JSONDecode, HttpService, raw)
            if not ok2 or type(data) ~= "table" then return end

            if data.type == "color_assign" then
                myColorHex = tostring(data.color or "#FFFFFF")
                return
            end

            if data.type == "self_join" then
                addMessage("System", "You connected to SNPWARE CHAT!", Color3.fromRGB(131, 255, 100))
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "SNPWARE CHAT";
                    Text  = "You connected to the server!";
                    Duration = 5;
                })
                return
            end

            if data.type == "join" then
                local name = tostring(data.name or "?")
                addMessage("System", name .. " connected to server!", Color3.fromRGB(136, 255, 100))
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "SNPWARE CHAT";
                    Text  = name .. " connected to server!";
                    Duration = 5;
                })
                return
            end

            if data.type == "leave" then
                local name = tostring(data.name or "?")
                addMessage("System", name .. " left the server.", Color3.fromRGB(180, 180, 180))
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "SNPWARE CHAT";
                    Text  = name .. " left the server.";
                    Duration = 5;
                })
                return
            end

            if data.type == "spam_warn" then
                local remaining = tonumber(data.remaining) or 60
                addMessage("System", "Too many request. Wait " .. remaining .. " sec.", Color3.fromRGB(255, 80, 80))
                return
            end

            if data.type == "history" then
                if type(data.messages) == "table" then
                    for _, msg in ipairs(data.messages) do
                        local histReply = nil
                        if type(msg.replyTo) == "table" then
                            histReply = {
                                name    = tostring(msg.replyTo.name    or "?"),
                                text    = tostring(msg.replyTo.text    or ""),
                                nameHex = tostring(msg.replyTo.nameHex or "#AAAAAA"),
                            }
                        end
                        addMessage(
                            tostring(msg.name or "?"),
                            tostring(msg.text or ""),
                            nil,
                            tostring(msg.color or "#FFFFFF"),
                            true,
                            histReply
                        )
                    end
                    task.wait()
                    messageList.CanvasPosition = Vector2.new(0, messageList.AbsoluteCanvasSize.Y)
                    updateScrollThumb()
                end
                return
            end

            if data.type == "server_list" then
                if type(data.servers) == "table" then
                    updateServerListUI(data.servers)
                end
                return
            end

            if data.type ~= "chat" then return end
            if type(data.name) ~= "string" or type(data.text) ~= "string" then return end

            local incomingReply = nil
            if type(data.replyTo) == "table" then
                incomingReply = {
                    name    = tostring(data.replyTo.name    or "?"),
                    text    = tostring(data.replyTo.text    or ""),
                    nameHex = tostring(data.replyTo.nameHex or "#AAAAAA"),
                }
            end
            addMessage(data.name, data.text, nil, tostring(data.color or "#FFFFFF"), false, incomingReply)
        end)

        ws.OnClose:Connect(function()
            wsConnected = false
            ws = nil
            warn("ChatService: closed reconnect wait 5s...")
            addMessage("System", "Disconnected from SNPWARE CHAT. Reconnecting in 5s...", Color3.fromRGB(255, 120, 80))
            pcall(function()
                game:GetService("StarterGui"):SetCore("SendNotification", {
                    Title = "SNPWARE CHAT";
                    Text  = "Connection lost. Reconnecting...";
                    Duration = 5;
                })
            end)
            task.delay(5, wsConnect)
        end)
    end

